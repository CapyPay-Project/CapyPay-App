---
import MainLayout from "../../layouts/MainLayout.astro";

import ProfileHeroCard from "../../components/account/profile/ProfileHeroCard.astro";
import ProfileInfoCards from "../../components/account/profile/ProfileInfoCards.astro";
import ProfileQuickSettingsCard from "../../components/account/profile/ProfileQuickSettingsCard.astro";
import ProfileConfigurationCard from "../../components/account/profile/ProfileConfigurationCard.astro";
import ProfileModals from "../../components/account/profile/ProfileModals.astro";

import { initProfilePage } from "../../utils/pages/profilePage.js";
---

<MainLayout title="Perfil | CapyPay" showSidebar={true}>
  <div
    class="flex flex-col gap-4 lg:gap-6 min-h-screen lg:h-full p-3 sm:p-4 lg:p-0 relative overflow-y-auto"
  >
    <header
      class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 lg:gap-4 shrink-0"
    >
      <div class="flex items-center gap-3 lg:gap-4 w-full md:w-auto">
        <a
          href="/dashboard"
          class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-slate-400 transition-colors hover:text-white hover:bg-white/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path></svg
          >
        </a>

        <div class="min-w-0 flex-1">
          <h1
            class="text-xl sm:text-2xl lg:text-3xl font-bold text-white truncate"
          >
            Mi Perfil
          </h1>
          <p class="text-slate-400 text-xs sm:text-sm mt-0.5 lg:mt-1">
            Tarjeta de identificación digital
          </p>
        </div>
      </div>
    </header>

    <ProfileHeroCard />

    <ProfileInfoCards />

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 lg:gap-6 pb-6">
      <ProfileQuickSettingsCard />
      <ProfileConfigurationCard />
    </div>

    <ProfileModals />
  </div>

  <style>
    @keyframes shimmer {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }

    .animate-shimmer {
      animation: shimmer 2s infinite;
    }

    .badge-tooltip {
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-4px);
      z-index: 10;
    }

    .badge-tooltip::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 4px solid transparent;
      border-top-color: rgba(0, 0, 0, 0.9);
    }
  </style>

  <script>
    import { initProfilePage } from "../../utils/pages/profilePage.js";
    initProfilePage();
  </script>
</MainLayout>
