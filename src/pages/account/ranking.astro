---
import MainLayout from "../../layouts/MainLayout.astro";
import RankingPodium from "../../components/ranking/RankingPodium.astro";
import RankingFacultyBattle from "../../components/ranking/RankingFacultyBattle.astro";
import RankingFilters from "../../components/ranking/RankingFilters.astro";
import RankingLeaderboard from "../../components/ranking/RankingLeaderboard.astro";
import RankingUserBar from "../../components/ranking/RankingUserBar.astro";
import RankingHowToEarn from "../../components/ranking/RankingHowToEarn.astro";
---

<MainLayout title="Ranking de Influencia | CapyPay" showSidebar={true}>
  <style is:global>
    .hexagon-clip { clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); }
    .glow-lime    { box-shadow: 0 0 20px rgba(215, 253, 73, 0.4); }
    .glow-pink    { box-shadow: 0 0 25px rgba(219, 39, 119, 0.6); }
    .glow-purple  { box-shadow: 0 0 25px rgba(124, 58, 237, 0.6); }
    .glow-neon-strong {
      box-shadow: 0 0 40px rgba(215, 253, 73, 0.8), 0 0 80px rgba(215, 253, 73, 0.4);
    }
    .text-accent-pink   { color: #db2777; }
    .text-accent-purple { color: #7c3aed; }
    .from-accent-purple {
      --tw-gradient-from: #7c3aed;
      --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgba(131, 98, 232, 0));
    }
    .user-highlight-card {
      background: linear-gradient(90deg, rgba(215, 253, 73, 0.15) 0%, rgba(215, 253, 73, 0.05) 100%);
      border: 1px solid rgba(215, 253, 73, 0.5);
      box-shadow: 0 0 15px rgba(215, 253, 73, 0.1) inset;
    }
    .particles-container {
      position: absolute; inset: -50px;
      pointer-events: none; z-index: 0;
      overflow: hidden; display: none;
    }
    .particle {
      position: absolute; width: 4px; height: 4px;
      background: #d7fd49; border-radius: 50%; opacity: 0.35;
      animation: falling-particle 3s infinite linear;
    }
    .particle:nth-child(1) { left: 20%; animation-delay: 0s; }
    .particle:nth-child(2) { left: 80%; animation-delay: 1.5s; }
    .particle:nth-child(3) { left: 50%; animation-delay: 0.8s; }
    @keyframes falling-particle {
      0%   { transform: translateY(-20px); opacity: 0; }
      10%  { opacity: 1; }
      100% { transform: translateY(150px); opacity: 0; }
    }
  </style>

  <div class="max-w-7xl mx-auto px-4 md:px-6 py-8 pb-32 overflow-x-hidden">

    <!-- Volver -->
    <a
      href="/services/comedor"
      class="inline-flex items-center gap-2 text-black/50 hover:text-brand-lime transition-colors mb-6 group font-bold uppercase tracking-wider text-xs"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      Volver a Comedor
    </a>

    <!-- Encabezado + Banner de premio -->
    <div class="flex flex-col lg:flex-row justify-between gap-6 mb-12">
      <div class="flex flex-col gap-2">
        <h1 class="text-black text-4xl md:text-5xl font-black leading-tight tracking-tight uppercase italic">
          Ranking de <span class="text-brand-lime">Influencia</span>
        </h1>
        <p class="text-black/60 text-lg max-w-xl font-medium">
          Compite con la comunidad estudiantil y ll&#233;vate el bot&#237;n semanal.
        </p>
      </div>

      <div class="flex-1 w-full lg:w-auto max-w-md mx-auto lg:mx-0 bg-linear-to-r from-accent-purple to-indigo-900  p-6 relative overflow-hidden flex items-center justify-between border border-white/20 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] border-4 border-black">
        <div class="relative z-10">
          <p class="text-xs font-bold uppercase tracking-widest text-black/70">
            Premio Semanal
            <span class="text-brand-lime ml-2" id="countdown-timer">00d 00h 00m</span>
          </p>
          <p class="text-2xl font-black text-black">10,000 BARAS + Merch</p>
          <button class="mt-3 bg-white text-accent-purple px-4 py-1.5  text-xs font-bold uppercase hover:bg-brand-lime hover:text-black transition-colors">
            Ver Detalles
          </button>
        </div>
        <span class="material-symbols-outlined text-7xl text-black/20 absolute -right-2 -bottom-2 rotate-12">redeem</span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex justify-center mb-8 gap-4">
      <button
        id="tab-users"
        class="tab-btn active px-6 py-2  font-bold uppercase tracking-widest text-sm bg-brand-lime text-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] border-4 border-black shadow-brand-lime/20 transition-all"
      >
        Estudiantes
      </button>
      <button
        id="tab-faculties"
        class="tab-btn px-6 py-2  font-bold uppercase tracking-widest text-sm bg-white border-2 border-black text-black/50 border-4 border-black hover:bg-white border-2 border-black transition-all"
      >
        Facultades &#x2694;&#xFE0F;
      </button>
    </div>

    <!-- Grid principal: columna izquierda (8/12) + sidebar derecho (4/12) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-8 space-y-8">
        <RankingPodium />
        <RankingFacultyBattle />
        <RankingFilters />
        <RankingLeaderboard />
        <RankingUserBar />
      </div>
      <RankingHowToEarn />
    </div>

  </div>
</MainLayout>

<script>
  // @ts-nocheck
  import { initRanking } from "../../utils/rankingLogic";
  initRanking();
</script>
