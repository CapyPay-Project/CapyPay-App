---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Ranking de Influencia | CapyPay" showSidebar={true}>
  <!-- Volver -->
  <a
    href="/dashboard"
    class="inline-flex items-center gap-2 text-black hover:text-[#d7fd48] transition-colors mb-6 group font-black uppercase tracking-wider text-sm border-2 border-transparent hover:border-black p-1 hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] bg-white"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 group-hover:-translate-x-1 transition-transform"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="3"
        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
    </svg>
    VOLVER
  </a>

  <!-- Header & Prize Banner -->
  <div
    class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 mb-12 border-b-4 border-black pb-8"
  >
    <div>
      <h1
        class="flex flex-col items-start gap-0 text-4xl sm:text-5xl lg:text-7xl font-black text-black uppercase tracking-tight relative"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        <span class="relative z-10 drop-shadow-[2px_2px_0px_white]"
          >RANKING DE</span
        >
        <span
          class="bg-[#d7fd48] px-3 py-1 border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] relative z-0 -mt-2 sm:-mt-4"
          >INFLUENCIA</span
        >
      </h1>
    </div>

    <div
      class="bg-black text-white border-4 border-black shadow-[6px_6px_0px_0px_rgba(215,253,73,1)] p-6 rotate-1 hover:rotate-0 transition-transform"
    >
      <p
        class="text-sm font-bold uppercase tracking-widest text-[#8CFFE1] mb-2"
      >
        PREMIO SEMANAL <span
          id="countdown-timer"
          class="ml-2 font-black text-[#d7fd48]">--d --h --m</span
        >
      </p>
      <p
        class="text-3xl font-black uppercase"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        10,000 BARAS + MERCH
      </p>
    </div>
  </div>

  <!-- Toggle Switch -->
  <div
    class="flex flex-col sm:flex-row gap-0 mb-12 border-4 border-black max-w-2xl mx-auto overflow-hidden shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] font-black"
  >
    <button
      id="tab-users"
      class="flex-1 py-4 sm:py-6 text-xl sm:text-2xl bg-[#d7fd48] text-black border-b-4 sm:border-b-0 sm:border-r-4 border-black uppercase active:translate-y-1 active:shadow-none transition-all"
      >ESTUDIANTES</button
    >
    <button
      id="tab-faculties"
      class="flex-1 py-4 sm:py-6 text-xl sm:text-2xl bg-white text-black/50 uppercase hover:bg-gray-100 transition-all"
      >FACULTADES</button
    >
  </div>

  <div
    class="grid grid-cols-1 xl:grid-cols-3 gap-8 mb-16"
    style="font-family: 'Space Grotesk', sans-serif;"
  >
    <!-- Main Content (Podium + Leaderboard) -->
    <div class="xl:col-span-2 space-y-12">
      <!-- Podium -->
      <div>
        <h2 class="text-4xl font-black uppercase tracking-tighter mb-8">
          EL PODIO
        </h2>
        <div
          id="podium-container"
          class="flex flex-col md:flex-row items-end justify-center gap-4 h-auto md:h-[450px] transition-opacity duration-300"
        >
          <!-- #2 -->
          <div
            class="w-full md:w-1/3 bg-[#8CFFE1] border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] flex flex-col items-center p-6 h-[320px] md:h-[350px] relative order-2 md:order-1 hover:-translate-y-2 transition-transform"
          >
            <div
              class="absolute -top-6 bg-black text-white px-4 py-1 text-2xl font-black"
            >
              #2
            </div>
            <div id="rank2-icon" class="hidden text-5xl mb-4"></div>
            <img
              id="rank2-avatar"
              alt="Avatar"
              class="w-24 h-24 border-4 border-black mb-4 bg-white object-cover"
              src="https://ui-avatars.com/api/?name=2&background=random"
            />
            <span
              id="rank2-name"
              class="font-black text-2xl uppercase text-center mt-auto truncate w-full"
              >...</span
            >
            <span id="rank2-points" class="font-bold text-4xl mt-2">0 XP</span>
          </div>

          <!-- #1 -->
          <div
            class="w-full md:w-1/3 bg-[#d7fd48] border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col items-center p-6 h-[380px] md:h-[420px] relative z-10 order-1 md:order-2 hover:-translate-y-4 transition-transform"
          >
            <div
              class="absolute -top-8 bg-black text-[#d7fd48] px-6 py-2 text-4xl font-black"
            >
              #1
            </div>
            <span
              class="material-symbols-outlined text-6xl text-black mb-2 absolute -top-16"
              style="font-variation-settings: 'FILL' 1;">&#x1f451;</span
            >
            <div id="rank1-icon" class="hidden text-6xl mb-4"></div>
            <img
              id="rank1-avatar"
              alt="Avatar"
              class="w-32 h-32 border-4 border-black mb-4 bg-white object-cover shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
              src="https://ui-avatars.com/api/?name=1&background=random"
            />
            <span
              id="rank1-name"
              class="font-black text-3xl uppercase text-center mt-auto truncate w-full"
              >...</span
            >
            <span id="rank1-points" class="font-bold text-5xl mt-2">0 XP</span>
          </div>

          <!-- #3 -->
          <div
            class="w-full md:w-1/3 bg-[#8b5cf6] border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] flex flex-col items-center p-6 h-[280px] md:h-[300px] relative order-3 md:order-3 hover:-translate-y-2 transition-transform"
          >
            <div
              class="absolute -top-6 bg-black text-white px-4 py-1 text-2xl font-black"
            >
              #3
            </div>
            <div id="rank3-icon" class="hidden text-5xl mb-4"></div>
            <img
              id="rank3-avatar"
              alt="Avatar"
              class="w-20 h-20 border-4 border-black mb-4 bg-white object-cover"
              src="https://ui-avatars.com/api/?name=3&background=random"
            />
            <span
              id="rank3-name"
              class="font-black text-2xl uppercase text-white text-center mt-auto truncate w-full"
              >...</span
            >
            <span id="rank3-points" class="font-bold text-4xl mt-2 text-white"
              >0 XP</span
            >
          </div>
        </div>
      </div>

      <!-- Leaderboard Table -->
      <div
        class="border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] overflow-hidden bg-white mt-12 md:mt-0"
      >
        <div
          id="ranking-list-title"
          class="bg-black text-white p-4 font-black text-xl uppercase tracking-widest border-b-4 border-black"
        >
          RANKING GENERAL
        </div>
        <div
          id="ranking-list-container"
          class="divide-y-4 divide-black min-h-[300px]"
        >
          <!-- JS WILL INJECT ROWS HERE -->
        </div>
        <div
          id="ranking-pagination"
          class="hidden p-4 bg-white flex justify-between items-center border-t-4 border-black"
        >
          <button
            id="pag-prev"
            class="border-4 border-black bg-white px-4 py-2 font-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-y-1 hover:shadow-none transition-all disabled:opacity-50 disabled:pointer-events-none"
            >&lt; ANT</button
          >
          <span id="pag-info" class="font-bold text-xl">1/1</span>
          <button
            id="pag-next"
            class="border-4 border-black bg-[#d7fd48] px-4 py-2 font-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-y-1 hover:shadow-none transition-all disabled:opacity-50 disabled:pointer-events-none"
            >SIG &gt;</button
          >
        </div>
      </div>
    </div>

    <!-- Sidebars -->
    <div class="space-y-8">
      <!-- Faculty Battle Card -->
      <div
        id="faculty-battle-summary"
        class="bg-white border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] p-6 -rotate-1 hover:rotate-0 transition-transform"
      >
        <h3 class="font-black text-3xl uppercase mb-6 tracking-tighter italic">
          FACULTY <span class="text-[#8b5cf6]">BATTLE</span>
        </h3>
        <div class="space-y-6">
          <div
            id="battle-details-text"
            class="flex justify-between font-black text-sm sm:text-lg mb-2"
          >
            Batalla de Facultades
          </div>
          <div class="hidden justify-between font-black text-sm sm:text-lg">
            <span
              class="bg-[#d7fd48] px-2 py-1 border-4 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
              >INGENIERIA</span
            >
            <span
              class="bg-[#8b5cf6] text-white px-2 py-1 border-4 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
              >ARTES</span
            >
          </div>
          <!-- Progress Bar -->
          <div
            id="battle-bar-container"
            class="h-12 border-4 border-black bg-[#8b5cf6] flex relative shadow-[inset_0px_4px_0px_rgba(0,0,0,0.2)]"
          >
          </div>
          <button
            class="w-full bg-black text-white py-4 font-black uppercase text-2xl border-4 border-black hover:bg-[#d7fd48] hover:text-black hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-y-1 transition-all"
            >VOTAR AHORA</button
          >
        </div>
      </div>

      <!-- How to earn XP -->
      <div
        class="bg-white border-4 border-black shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] p-6 rotate-1 hover:rotate-0 transition-transform"
      >
        <h3
          class="font-black text-2xl uppercase mb-6 border-b-4 border-black pb-4"
        >
          COMO GANAR <span class="bg-[#d7fd48] px-1 border-2 border-black"
            >XP</span
          >
        </h3>
        <ul class="space-y-4 font-bold text-lg">
          <li
            class="flex items-center gap-4 p-2 hover:bg-gray-100 border-2 border-transparent hover:border-black transition-colors"
          >
            <span
              class="bg-[#d7fd48] text-black w-8 h-8 flex items-center justify-center border-2 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
              >1</span
            >
            <span class="uppercase">MISIONES SEMANALES</span>
          </li>
          <li
            class="flex items-center gap-4 p-2 hover:bg-gray-100 border-2 border-transparent hover:border-black transition-colors"
          >
            <span
              class="bg-[#8CFFE1] text-black w-8 h-8 flex items-center justify-center border-2 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
              >2</span
            >
            <span class="uppercase">COMPRAR EN CANTINAS</span>
          </li>
          <li
            class="flex items-center gap-4 p-2 hover:bg-gray-100 border-2 border-transparent hover:border-black transition-colors"
          >
            <span
              class="bg-[#8b5cf6] text-white w-8 h-8 flex items-center justify-center border-2 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
              >3</span
            >
            <span class="uppercase">VOTAR EN RETOS</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Sticky Bottom Card: TU POSICIÓN -->
  <div
    class="fixed bottom-20 md:bottom-6 right-4 md:right-8 z-30 transform hover:-translate-y-2 transition-transform"
  >
    <div
      class="bg-[#8b5cf6] border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-4 sm:p-6 flex items-center gap-4 sm:gap-6 active:translate-y-1 active:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all cursor-pointer"
    >
      <div class="text-white">
        <p
          class="font-black text-xs uppercase tracking-widest leading-none mb-1 text-[#d7fd48]"
        >
          TU POSICIÓN
        </p>
        <p id="user-rank" class="font-black text-4xl sm:text-5xl leading-none">
          #--
        </p>
      </div>
      <div class="h-16 w-1 bg-black"></div>
      <div class="text-white hidden sm:flex flex-col">
        <p
          class="font-black text-xs uppercase tracking-widest leading-none mb-1"
        >
          XP ACUMULADA
        </p>
        <p
          id="user-points-footer"
          class="font-black text-2xl sm:text-3xl leading-none"
        >
          0
        </p>
      </div>
      <div class="flex-col items-center justify-center ml-2 hidden sm:flex">
        <img
          id="user-avatar-footer"
          class="w-10 h-10 border-2 border-black bg-white object-cover shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
          src="https://ui-avatars.com/api/?name=U&background=random"
        />
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { initRanking } from "../../utils/rankingLogic.js";
  document.addEventListener("DOMContentLoaded", () => {
    initRanking();
  });
</script>
