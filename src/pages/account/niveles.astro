---
import CapyPay from "../../layouts/MainLayout.astro";
import RankProgression from "../../components/dashboard/gamification/RankProgression.astro";
const url = new URL(Astro.request.url);
const xpParam = url.searchParams.get("xp");
const fromParam = url.searchParams.get("from");
const xpParsed = Number.parseInt(xpParam ?? "", 10);
const puntosActuales =
  Number.isFinite(xpParsed) && xpParsed >= 0 ? xpParsed : 1500;
const mostrarDemo = import.meta.env.DEV || url.searchParams.get("demo") === "1";
const fromDashboard = fromParam === "dashboard";
---

<CapyPay title="Niveles | CapyPay" showSidebar={true}>
  <div class="w-full max-w-6xl mx-auto px-2 sm:px-4 lg:px-2">
    <!-- Header -->
    <header
      class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 lg:gap-4 shrink-0 mb-6"
    >
      <div class="flex items-center gap-3 lg:gap-4 w-full md:w-auto">
        <a
          href="/dashboard"
          class="w-9 h-9 lg:w-10 lg:h-10  border-4 border-black flex items-center justify-center text-black font-bold hover:text-black hover:bg-white border-2 border-black transition-colors shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 lg:h-5 lg:w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </a>
        <div class="min-w-0 flex-1">
          <h1
            class="text-xl sm:text-2xl lg:text-3xl font-bold text-black truncate"
          >
            Mis Niveles
          </h1>
          <p class="text-black font-bold text-xs sm:text-sm mt-0.5 lg:mt-1">
            Visualiza tu progreso y desbloquea recompensas
          </p>
        </div>
      </div>

      <div
        id="xp-sync-badge"
        class="text-[11px] md:text-xs px-3 py-1  border-4 border-black text-slate-700 bg-white border-2 border-black"
        aria-live="polite"
      >
        Sincronizando XP...
      </div>
    </header>

    {
      fromDashboard && (
        <div
          id="from-dashboard-banner"
          class="mb-4 bg-[#d7fd48] border-4 border-black px-4 py-3 text-black font-black uppercase text-xs sm:text-sm shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] opacity-0 translate-y-1 transition-all duration-500"
        >
          Llegaste desde dashboard: aquí puedes ver tu progreso y beneficios por nivel.
        </div>
      )
    }

    {
      mostrarDemo && (
        <div class="bg-black/60 backdrop-blur-lg border-4 border-black -3xl p-4 mb-6">
          <h3 class="text-black text-sm font-bold mb-3 flex items-center gap-2">
            <svg
              class="w-4 h-4 text-brand-lime"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
              />
            </svg>
            Panel de Control (Demo)
          </h3>
          <div class="flex flex-wrap gap-2">
            <button
              type="button"
              class="xp-demo-btn px-3 py-1.5 bg-white border-2 border-black hover:bg-white border-2 border-black text-black text-xs font-bold  transition-colors border-4 border-black hover:border-brand-lime/30"
              data-xp="200"
            >
              Novato (200 XP)
            </button>
            <button
              type="button"
              class="xp-demo-btn px-3 py-1.5 bg-white border-2 border-black hover:bg-white border-2 border-black text-black text-xs font-bold  transition-colors border-4 border-black hover:border-brand-lime/30"
              data-xp="1500"
            >
              Bachiller (1,500 XP)
            </button>
            <button
              type="button"
              class="xp-demo-btn px-3 py-1.5 bg-white border-2 border-black hover:bg-white border-2 border-black text-black text-xs font-bold  transition-colors border-4 border-black hover:border-brand-lime/30"
              data-xp="3500"
            >
              Licenciado (3,500 XP)
            </button>
            <button
              type="button"
              class="xp-demo-btn px-3 py-1.5 bg-white border-2 border-black hover:bg-white border-2 border-black text-black text-xs font-bold  transition-colors border-4 border-black hover:border-brand-lime/30"
              data-xp="7500"
            >
              Magíster (7,500 XP)
            </button>
            <button
              type="button"
              class="xp-demo-btn px-3 py-1.5 bg-white border-2 border-black hover:bg-white border-2 border-black text-black text-xs font-bold  transition-colors border-4 border-black hover:border-brand-lime/30"
              data-xp="12000"
            >
              Doctorado (12,000 XP)
            </button>
          </div>
          <p class="text-black font-semibold text-xs mt-2">
            Solo en desarrollo (o con <code>?demo=1</code>). Simula XP para
            pruebas visuales.
          </p>
        </div>
      )
    }

    <!-- Módulo de Niveles -->
    <div id="modulo-niveles-wrapper">
      <RankProgression puntosActuales={puntosActuales} />
    </div>

    <!-- Espaciador para Bottom Nav en móvil -->
    <div class="lg:hidden h-24 w-full"></div>
  </div>

  <script>
    import { authService } from "../../services/api";

    declare global {
      interface Window {
        actualizarXPModulo?: (xp: number) => void;
        actualizarTarjetaDashboard?: (xp: number) => void;
      }
    }

    function parseXP(value: unknown, fallback = 0): number {
      const parsed = Number.parseInt(String(value ?? ""), 10);
      return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;
    }

    function updateSyncBadge(
      text: string,
      tone: "neutral" | "ok" | "warn" | "error" = "neutral",
    ) {
      const badge = document.getElementById("xp-sync-badge");
      if (!badge) return;
      badge.textContent = text;

      badge.classList.remove(
        "text-slate-700",
        "text-brand-lime",
        "text-amber-300",
        "text-red-300",
        "bg-white",
        "border-2",
        "border-black",
        "bg-brand-lime/10",
        "bg-amber-400/10",
        "bg-red-400/10",
      );

      if (tone === "ok") {
        badge.classList.add("text-brand-lime", "bg-brand-lime/10");
      } else if (tone === "warn") {
        badge.classList.add("text-amber-300", "bg-amber-400/10");
      } else if (tone === "error") {
        badge.classList.add("text-red-300", "bg-red-400/10");
      } else {
        badge.classList.add("text-slate-700", "bg-white", "border-2", "border-black");
      }
    }

    function persistXPInCache(xp: number) {
      localStorage.setItem("capypay_user_xp", String(xp));

      try {
        const userStr = localStorage.getItem("capypay_user");
        if (!userStr) return;
        const user = JSON.parse(userStr);
        user.xp = xp;
        localStorage.setItem("capypay_user", JSON.stringify(user));
      } catch (e) {
        console.warn("No se pudo persistir XP en capypay_user:", e);
      }
    }

    function applyXPToUI(xp: number, source = "cache") {
      if (!Number.isFinite(xp) || xp < 0) return;

      window.actualizarXPModulo?.(xp);
      window.actualizarTarjetaDashboard?.(xp);
      persistXPInCache(xp);

      window.dispatchEvent(
        new CustomEvent("capypay-xp-updated", {
          detail: { xp, source },
        }),
      );

      updateSyncBadge(
        source === "server"
          ? `XP sincronizada (${xp.toLocaleString("es-VE")})`
          : `XP local (${xp.toLocaleString("es-VE")})`,
        source === "server" ? "ok" : "neutral",
      );
    }

    const container = document.getElementById("modulo-niveles-wrapper");
    if (container) {
      container.style.transition = "opacity 0.2s ease, transform 0.2s ease";
    }

    document.addEventListener("DOMContentLoaded", async () => {
      const params = new URLSearchParams(window.location.search);
      const fromDashboard = params.get("from") === "dashboard";
      const fromDashboardBanner = document.getElementById("from-dashboard-banner");

      if (fromDashboardBanner) {
        requestAnimationFrame(() => {
          fromDashboardBanner.classList.remove("opacity-0", "translate-y-1");
        });

        setTimeout(() => {
          fromDashboardBanner.classList.add("opacity-0", "-translate-y-1");
        }, 2400);

        setTimeout(() => {
          fromDashboardBanner.remove();
        }, 3000);
      }

      if (fromDashboard && container) {
        container.style.boxShadow = "0 0 0 4px #000, 0 0 0 8px #d7fd48";
        container.style.transform = "translateY(-2px)";

        setTimeout(() => {
          container.style.boxShadow = "none";
          container.style.transform = "translateY(0)";
        }, 1800);
      }

      updateSyncBadge("Cargando XP local...");

      // 1) Carga inmediata desde caché (SWR)
      const userStr = localStorage.getItem("capypay_user");
      let currentXP = parseXP(localStorage.getItem("capypay_user_xp"), 0);

      if (currentXP <= 0 && userStr) {
        try {
          const user = JSON.parse(userStr);
          currentXP = parseXP(user?.xp ?? user?.puntos, 0);
        } catch (e) {
          console.error("Error leyendo caché de usuario", e);
        }
      }

      if (currentXP > 0) {
        applyXPToUI(currentXP, "cache");
      } else {
        updateSyncBadge("Sin XP en caché, consultando servidor...", "warn");
      }

      // 2) Revalidar con servidor en segundo plano
      try {
        const freshUser = await authService.getProfile();
        const freshXP = parseXP(freshUser?.xp, currentXP);

        if (Number.isFinite(freshXP) && freshXP >= 0) {
          if (freshXP !== currentXP && typeof window.showToast === "function") {
            window.showToast(
              `XP actualizada a ${freshXP.toLocaleString("es-VE")}`,
              "success",
              "Progreso sincronizado",
            );
          }
          applyXPToUI(freshXP, "server");
        }
      } catch (err) {
        console.log("Usando versión en caché (offline o error de red)", err);
        updateSyncBadge("Modo caché (sin conexión al servidor)", "warn");
      }

      // 3) Demo panel (solo si existe en el DOM)
      const demoBtns = document.querySelectorAll(".xp-demo-btn");
      demoBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          const xpValue = parseXP(btn.getAttribute("data-xp"), 0);
          console.log("Simulando XP (Demo):", xpValue);
          applyXPToUI(xpValue, "demo");
          updateSyncBadge(
            `Modo demo: ${xpValue.toLocaleString("es-VE")} XP`,
            "warn",
          );
        });
      });

      // 4) Sincronización entre pestañas
      window.addEventListener("storage", (event) => {
        if (event.key === "capypay_user_xp" && event.newValue) {
          const xpFromOtherTab = parseXP(event.newValue, currentXP);
          applyXPToUI(xpFromOtherTab, "cache");
        }
      });
    });
  </script>
</CapyPay>


