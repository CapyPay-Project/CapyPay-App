---
import MainLayout from "../../layouts/MainLayout.astro";
import { Card, Button, Input } from "../../components/ui";
import ProfileConfigurationCard from "../../components/account/profile/ProfileConfigurationCard.astro";
import ProfileModals from "../../components/account/profile/ProfileModals.astro";
---

<MainLayout title="Configuración | CapyPay" showSidebar={true}>
  <div class="flex flex-col gap-6 h-full p-4 lg:p-0">
    <!-- Header -->
    <Card
      class="flex flex-col md:flex-row justify-between items-start md:items-center p-6 relative overflow-hidden group"
    >
      <div
        class="absolute -top-24 -right-24 w-48 h-48 bg-brand-lime/10 blur-3xl group-hover:bg-brand-lime/20 transition-all duration-700"
      >
      </div>

      <div class="relative z-10">
        <h1
          class="text-3xl lg:text-4xl font-black text-black mb-2 uppercase tracking-tighter"
        >
          AJUSTES DE CUENTA
        </h1>
        <p class="text-black font-bold text-sm">
          Administra tus preferencias personales y de la cuenta.
        </p>
      </div>
    </Card>

    <!-- Settings Content -->
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-6 flex-1 overflow-y-auto custom-scrollbar"
    >
      <!-- Profile Settings -->
      <Card class="h-fit lg:col-span-2">
        <h2 class="text-xl font-bold text-black mb-6 flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-brand-lime"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
          </svg>
          Perfil
        </h2>
        <form class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label
              class="block text-black font-black text-sm mb-2 uppercase tracking-wide"
              >Nombre de Usuario</label
            >
            <Input id="profile-name" type="text" />
          </div>
          <div>
            <label
              class="block text-black font-black text-sm mb-2 uppercase tracking-wide"
              >Correo Electrónico</label
            >
            <Input id="profile-email" type="email" />
          </div>
          <div>
            <label
              class="block text-black font-black text-sm mb-2 uppercase tracking-wide"
              >Cédula</label
            >
            <Input
              id="profile-cedula"
              type="text"
              readonly
              class="text-black font-semibold bg-gray-100 cursor-not-allowed"
            />
          </div>

          <div class="md:col-span-2 mt-4">
            <Button
              id="btn-save-profile"
              type="button"
              variant="primary"
              class="w-full sm:w-auto"
            >
              Guardar Cambios
            </Button>
          </div>
        </form>
      </Card>

      <!-- Security Settings -->
      <Card class="h-fit">
        <h2 class="text-xl font-bold text-black mb-6 flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-brand-lime"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
          Seguridad
        </h2>

        <div class="space-y-4">
          <div class="bg-white border-4 border-black p-6">
            <h3
              class="text-black font-black text-sm mb-1 uppercase tracking-wide"
            >
            </h3>
            <p class="text-black font-bold text-xs mb-4">
              Establece un código de 4 o 6 dígitos para autorizar pagos.
            </p>

            <div class="flex gap-2 mb-4">
              <Input
                type="password"
                id="pin-input"
                maxlength="6"
                placeholder="0000"
                class="text-center tracking-[0.5em] font-bold placeholder:tracking-normal placeholder:font-normal"
              />
            </div>

            <Button
              id="btn-save-pin"
              variant="secondary"
              class="w-full border-black hover:-translate-y-1 hover:shadow-none shadow-[2px_2px_0_0_#000] transition-all"
              size="sm"
            >
              Actualizar PIN
            </Button>
          </div>

          <div
            class="bg-white border-4 border-black p-6 opacity-50 cursor-not-allowed"
          >
            <h3
              class="text-black font-black text-sm mb-1 uppercase tracking-wide"
            >
              Cambiar Contraseña
            </h3>
            <p class="text-black font-bold text-xs">Próximamente disponible.</p>
          </div>
        </div>
      </Card>
      <ProfileConfigurationCard />

      <!-- Dev Zone -->
      <Card class="h-fit lg:col-span-2 bg-red-100 border-red-500">
        <h2 class="text-xl font-bold text-black mb-6 flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 text-red-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          Dev Zone
        </h2>
        <div class="space-y-4">
          <p class="text-black font-bold text-xs">
            Herramientas de desarrollador. Úsalo con precaución.
          </p>
          <Button
            id="btn-dev-complete-orders"
            variant="secondary"
            class="w-full bg-red-500 text-white border-black hover:bg-red-400 font-bold uppercase tracking-widest"
          >
            Marcar Todos los Pedidos Como Listos
          </Button>
        </div>
      </Card>
    </div>
  </div>
  <ProfileModals />
</MainLayout>

<script>
  // @ts-nocheck
  import { initProfilePage } from "../../utils/pages/profilePage.js";
  import { authService, userService } from "../../services/api.js";

  initProfilePage();

  const nameInput = document.getElementById("profile-name");
  const emailInput = document.getElementById("profile-email");
  const cedulaInput = document.getElementById("profile-cedula");
  const btnSave = document.getElementById("btn-save-profile");

  async function loadProfile() {
    try {
      const user = authService.getCurrentUser();
      if (!user) return; // No logueado

      // Intentar obtener datos frescos del backend
      const userId = user.id || user.usuarioId;
      if (!userId) return;

      const profile = await userService.getProfile(userId);

      if (profile) {
        if (nameInput) nameInput.value = profile.nombre || profile.name || "";
        if (emailInput) emailInput.value = profile.email || "";
        if (cedulaInput) cedulaInput.value = profile.cedula || "";
      }
    } catch (e) {
      console.error("Error loading settings:", e);
    }
  }

  loadProfile();

  if (btnSave) {
    btnSave.addEventListener("click", async () => {
      // TODO: Implementar Update en Backend
      alert("La función de actualizar perfil estará disponible pronto.");
    });
  }

  // --- PIN UPDATE LOGIC ---
  const btnSavePin = document.getElementById("btn-save-pin");
  if (btnSavePin) {
    btnSavePin.addEventListener("click", async () => {
      const pinInput = document.getElementById("pin-input");
      const pin = pinInput ? pinInput.value : "";

      if ((pin.length !== 4 && pin.length !== 6) || isNaN(Number(pin))) {
        alert("El PIN debe ser de 4 o 6 números.");
        return;
      }

      const user = authService.getCurrentUser();
      if (!user) return;

      const userId = user.id || user.usuarioId || user._id;

      const originalText = btnSavePin.innerText;
      btnSavePin.innerText = "Guardando...";
      btnSavePin.disabled = true;

      try {
        // TODO: Mover esto a userService en api.js
        const response = await fetch(
          `http://localhost:3000/api/usuario/${userId}/pin`,
          {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ pin }),
          },
        );

        const data = await response.json();

        if (response.ok) {
          alert("PIN actualizado con éxito.");
          pinInput.value = "";
        } else {
          alert("Error: " + (data.error || "No se pudo actualizar"));
        }
      } catch (e) {
        console.error(e);
        alert("Error de conexión");
      } finally {
        btnSavePin.innerText = originalText;
        btnSavePin.disabled = false;
      }
    });
  }

  // --- DEV ZONE LOGIC ---
  const btnDevComplete = document.getElementById("btn-dev-complete-orders");
  if (btnDevComplete) {
    btnDevComplete.addEventListener("click", async () => {
      const originalText = btnDevComplete.innerText;
      btnDevComplete.innerText = "Procesando...";
      btnDevComplete.disabled = true;

      try {
        const response = await fetch(
          "http://localhost:3000/api/comedor/complete-all",
          { method: "POST" },
        );
        if (response.ok) {
          alert("Todos los pedidos en pre arrival ahora están ready");
        } else {
          alert("Error al completar pedidos");
        }
      } catch (e) {
        console.error(e);
        alert("Error de conexión");
      } finally {
        btnDevComplete.innerText = originalText;
        btnDevComplete.disabled = false;
      }
    });
  }
</script>
