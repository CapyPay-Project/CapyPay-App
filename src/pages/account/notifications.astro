---
import MainLayout from "../../layouts/MainLayout.astro";
import NavBar from "../../components/layout/NavBar.astro";
import ToastNotification from "../../components/ui/ToastNotification.astro";
import { Card, Button } from "../../components/ui";
---

<MainLayout title="Notificaciones | CapyPay" showSidebar={true}>
  <div
    class="flex flex-col gap-4 lg:gap-6 min-h-screen lg:h-full p-3 sm:p-4 lg:p-0 relative overflow-y-auto"
  >
    <!-- Header Page -->
    <header class="flex justify-between items-center gap-3 lg:gap-4 shrink-0">
      <div class="flex items-center gap-3 lg:gap-4 min-w-0">
        <Button
          href="/dashboard"
          variant="secondary"
          size="icon"
          class="shrink-0 text-black font-bold hover:text-black border-black"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </Button>
        <div class="min-w-0">
          <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold text-black">
            Notificaciones
          </h1>
          <p class="text-black font-bold text-xs sm:text-sm mt-0.5 lg:mt-1">
            Mantente al día con tus actividades
          </p>
        </div>
      </div>

      <!-- Botón Limpiar -->
      <Button
        id="clear-notifications-btn"
        variant="ghost"
        class="shrink-0 bg-[#ff4d4d] border-4 border-black text-white hover:translate-y-1 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none transition-all group px-4 py-2"
      >
        <svg
          slot="icon-left"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 group-hover:rotate-12 transition-transform duration-300"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="square"
            stroke-linejoin="miter"
            stroke-width="3"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
          ></path>
        </svg>
        <span
          class="text-xs sm:text-sm font-black hidden sm:inline uppercase tracking-widest"
          >Limpiar</span
        >
      </Button>
    </header>

    <!-- Contador de no leídas -->
    <div
      id="unread-counter"
      class="flex bg-[#d7fd48] border-4 border-black text-black px-4 py-3 mb-4 items-center justify-between shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] uppercase"
      style="display: none;"
    >
      <span class="text-sm font-black flex items-center gap-3">
        <span class="w-3 h-3 bg-[#ff4d4d] border-2 border-black animate-pulse"
        ></span>
        Tienes <span id="unread-count" class="font-black text-lg underline mx-1"
          >0</span
        > sin leer
      </span>
      <Button
        id="mark-all-read-btn"
        variant="primary"
        size="sm"
        class="text-xs font-black bg-white hover:bg-gray-100 hover:translate-y-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:shadow-none transition-all"
      >
        Marcar todas
      </Button>
    </div>

    <!-- Lista de Notificaciones -->
    <div
      id="notifications-container"
      class="space-y-3 pb-32 lg:pb-0 animate-fade-in-up"
    >
      <!-- Estado de carga -->
      <div
        class="p-8 text-center animate-fade-in-up bg-white border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative overflow-hidden"
      >
        <div class="flex flex-col items-center gap-4">
          <div
            class="w-16 h-16 bg-[#d7fd48] border-4 border-black flex items-center justify-center animate-pulse"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8 text-black"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
              ></path>
            </svg>
          </div>
          <p class="text-black font-black text-xl uppercase tracking-tighter">
            Cargando notificaciones...
          </p>
        </div>
      </div>

      <!-- Spacer para bottom nav en mobile -->
      <div class="lg:hidden h-20 w-full shrink-0"></div>
    </div>
  </div>

  <style>
    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in-down {
      animation: fadeInDown 0.5s ease-out forwards;
    }

    .animate-fade-in-up {
      animation: fadeInUp 0.5s ease-out forwards;
      opacity: 0;
      animation-delay: 0.1s;
    }
  </style>

  <script>
    // @ts-nocheck
    import { authService, notificationService } from "../../services/api.js";

    let notifications = [];

    async function loadNotifications() {
      const container = document.getElementById("notifications-container");
      const user = authService.getCurrentUser();

      if (!user || (!user.id && !user.usuarioId && !user._id)) {
        container.innerHTML =
          '<div class="text-center py-20"><p class="text-red-500 text-sm">Error: No hay sesión activa</p></div>';
        return;
      }

      try {
        const userId = user.id || user.usuarioId || user._id;
        const { notifications: notifs } =
          await notificationService.getNotifications(userId);

        notifications = notifs || [];
        renderNotifications();
      } catch (e) {
        console.error("Error cargando notificaciones:", e);
        container.innerHTML =
          '<div class="text-center py-20"><p class="text-red-500 text-sm">Error al cargar notificaciones</p></div>';
      }
    }

    function renderNotifications() {
      const container = document.getElementById("notifications-container");
      const unreadCounter = document.getElementById("unread-counter");
      const unreadCountEl = document.getElementById("unread-count");
      const clearBtn = document.getElementById("clear-notifications-btn");

      // Calcular no leídas
      const unreadCount = notifications.filter((n) => !n.is_read).length;

      // Mostrar/ocultar contador de no leídas
      if (unreadCount > 0) {
        unreadCounter.style.display = "flex";
        unreadCountEl.innerText = unreadCount;
      } else {
        unreadCounter.style.display = "none";
      }

      // Habilitar/deshabilitar botón limpiar
      if (clearBtn) {
        clearBtn.disabled = notifications.length === 0;
      }

      // Bandeja vacía
      if (notifications.length === 0) {
        container.innerHTML = `
        <div class="bg-white border-4 border-black p-8 text-center animate-fade-in-up shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative overflow-hidden">
          <div class="relative z-10 w-full flex flex-col items-center">
            <div class="w-24 h-24 bg-[#ff4d4d] border-4 border-black mb-6 flex items-center justify-center shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
              </svg>
            </div>
            <h3 class="text-3xl font-black text-black mb-3 uppercase tracking-tighter">Bandeja vacía</h3>   
            <p class="text-black font-bold text-sm bg-[#e5e5e5] px-3 py-1 border-2 border-black inline-block uppercase">No tienes notificaciones nuevas</p>
          </div>
        </div>`;
        return;
      }

      // Renderizar notificaciones
      let html = '<div class="space-y-3">';

      notifications.forEach((notif, index) => {
        const icon = notif.type === "payment_received" ? "💰" : "📢";
        const isUnread = !notif.is_read;

        // Neo-Brutalist styling
        const mainBg = isUnread ? "bg-[#d7fd48]" : "bg-white";
        const iconBg = "bg-white border-2 border-black";

        const dateStr = new Date(notif.created_at).toLocaleString("es-VE", {
          day: "2-digit",
          month: "short",
          year: "numeric",
          hour: "2-digit",
          minute: "2-digit",
        });

        html += `
         <div class="border-4 border-black p-4 transition-all cursor-pointer group shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-1 hover:translate-y-1 hover:shadow-none ${mainBg}"
              style="animation-delay: ${index * 0.05}s"
              onclick="window.handleNotificationClick('${notif.id}', ${isUnread})">
          <div class="flex gap-4">
            <!-- Icono -->
            <div class="shrink-0 w-14 h-14 ${iconBg} flex items-center justify-center text-2xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
              ${icon}
            </div>

            <!-- Contenido -->
            <div class="flex-1 min-w-0 flex flex-col justify-center">
              <div class="flex items-start justify-between gap-2 mb-1">
                <p class="text-sm sm:text-base font-black text-black leading-tight uppercase relative">
                  ${notif.message}
                  ${
                    isUnread
                      ? '<span class="inline-block shrink-0 w-3 h-3 bg-[#ff4d4d] border-2 border-black rounded-none ml-2"></span>'
                      : ""
                  }
                </p>
              </div>
              <p class="text-xs text-black font-bold uppercase tracking-widest mt-1">${dateStr}</p>
            </div>

            <!-- Flecha/Acción -->
            <div class="shrink-0 flex items-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="3" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      `;
      });

      html += "</div>";
      container.innerHTML = html;
    }

    // Manejador para click en notificación
    window.handleNotificationClick = async (notifId, isUnread) => {
      if (isUnread) {
        try {
          await notificationService.markAsRead(notifId);
          // Actualizar estado local
          const notif = notifications.find((n) => n.id === notifId);
          if (notif) notif.is_read = true;
          renderNotifications();
        } catch (e) {
          console.error("Error marcando notificación como leída:", e);
        }
      }
    };

    // Limpiar todas las notificaciones
    document.addEventListener("DOMContentLoaded", () => {
      const clearBtn = document.getElementById("clear-notifications-btn");
      const markAllReadBtn = document.getElementById("mark-all-read-btn");

      if (clearBtn) {
        clearBtn.addEventListener("click", async () => {
          if (notifications.length === 0) return;

          // Confirmación
          if (
            !confirm(
              "¿Estás seguro de que quieres limpiar todas las notificaciones?",
            )
          ) {
            return;
          }

          const user = authService.getCurrentUser();
          if (!user) return;

          try {
            const userId = user.id || user.usuarioId || user._id;
            await notificationService.clearAll(userId);

            // Actualizar estado local
            notifications = [];
            renderNotifications();

            if (window.showToast) {
              window.showToast(
                "Notificaciones eliminadas",
                "success",
                "Bandeja limpia",
              );
            }
          } catch (e) {
            console.error("Error limpiando notificaciones:", e);
            if (window.showToast) {
              window.showToast("Error al limpiar notificaciones", "error");
            }
          }
        });
      }

      // Marcar todas como leídas
      if (markAllReadBtn) {
        markAllReadBtn.addEventListener("click", async () => {
          const user = authService.getCurrentUser();
          if (!user) return;

          try {
            const userId = user.id || user.usuarioId || user._id;
            // Obtener no leídas
            const unreadNotifs = notifications.filter((n) => !n.is_read);

            // Marcar cada una como leída
            for (const notif of unreadNotifs) {
              await notificationService.markAsRead(notif.id);
              notif.is_read = true;
            }

            renderNotifications();

            if (window.showToast) {
              window.showToast(
                "Todas las notificaciones marcadas como leídas",
                "success",
              );
            }
          } catch (e) {
            console.error("Error marcando como leídas:", e);
          }
        });
      }

      // Cargar notificaciones
      loadNotifications();
    });
  </script>
</MainLayout>
