---
import MainLayout from "../../layouts/MainLayout.astro";
import BcvTickerPanel from "../../components/dashboard/finance/BcvTickerPanel.astro";
---

<MainLayout title="Recargar Saldo | CapyPay" showSidebar={true}>
  <div
    class="flex flex-col gap-6 lg:gap-8 min-h-[90vh] p-4 lg:p-6 mb-20 relative font-sans"
  >
    <!-- HEADER NEO-BRUTALISTA -->
    <header
      class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-[#8b5cf6] border-4 border-black p-4 lg:p-6 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)]"
    >
      <div class="flex items-center gap-4 w-full md:w-auto">
        <a
          href="/dashboard"
          class="w-12 h-12 bg-white border-4 border-black flex items-center justify-center text-black font-black hover:-translate-y-1 hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:bg-[#d7fd48] transition-all shrink-0"
        >
          <span class="material-symbols-outlined font-black">arrow_back</span>
        </a>
        <div class="flex flex-col">
          <h1
            class="text-3xl lg:text-4xl font-black text-white uppercase tracking-widest drop-shadow-[2px_2px_0px_rgba(0,0,0,1)]"
          >
            Recargar
          </h1>
          <p class="text-lg font-bold text-white border-black">
            AGREGA FONDOS A TU BILLETERA
          </p>
        </div>
      </div>
      <div class="w-full md:w-auto mt-2 md:mt-0">
        <BcvTickerPanel />
      </div>
    </header>

    <!-- WIZARD CONTAINER -->
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8 w-full">
      <!-- PANEL IZQUIERDO: FORMULARIO -->
      <section
        class="flex-1 bg-white border-4 border-black p-6 lg:p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]"
      >
        <h2
          class="text-2xl font-black uppercase text-black mb-6 border-b-4 border-black pb-2"
        >
          Datos de la Recarga
        </h2>

        <form id="recarga-form" class="flex flex-col gap-6">
          <div class="flex flex-col gap-2">
            <label class="font-black text-lg uppercase"
              >Cédula Asociada a la Cuenta CapyPay</label
            >
            <input
              type="text"
              id="cedula"
              name="cedula"
              required
              placeholder="V-12345678"
              class="w-full bg-[#f4f4f5] border-4 border-black p-4 font-bold text-black focus:outline-none focus:bg-[#d7fd48] transition-colors placeholder:text-gray-500"
            />
            <p class="text-sm font-bold text-gray-600">
              Requerido para validar tu identidad.
            </p>
          </div>

          <div class="flex flex-col gap-2">
            <label class="font-black text-lg uppercase"
              >Monto a Transferir (Bs.)</label
            >
            <div class="relative">
              <span
                class="absolute left-4 top-1/2 -translate-y-1/2 font-black text-xl"
                >Bs.</span
              >
              <input
                type="number"
                id="monto_bs"
                name="monto_bs"
                min="1"
                step="0.01"
                required
                placeholder="0.00"
                class="w-full bg-[#f4f4f5] border-4 border-black p-4 pl-14 font-bold text-black text-xl focus:outline-none focus:bg-[#d7fd48] transition-colors"
              />
            </div>
            <p class="text-sm font-bold text-gray-600" id="monto-capy-preview">
              Monto estimado en capys: 0.00
            </p>
          </div>

          <div class="flex flex-col gap-2">
            <label class="font-black text-lg uppercase"
              >Método de Pago Utilizado</label
            >
            <select
              id="metodo_pago"
              name="metodo_pago"
              required
              class="w-full bg-[#f4f4f5] border-4 border-black p-4 font-bold text-black focus:outline-none focus:bg-[#d7fd48] transition-colors appearance-none cursor-pointer"
            >
              <option value="" disabled selected
                >-- SELECCIONA EL MÉTODO --</option
              >
              <option value="pago_movil">Pago Móvil</option>
              <option value="transferencia">Transferencia Bancaria</option>
              <option value="efectivo">Efectivo (Taquilla)</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label class="font-black text-lg uppercase"
              >Número de Referencia</label
            >
            <input
              type="text"
              id="reference_number"
              name="reference_number"
              required
              placeholder="Ej. 123456"
              class="w-full bg-[#f4f4f5] border-4 border-black p-4 font-bold text-black focus:outline-none focus:bg-[#d7fd48] transition-colors"
            />
            <p class="text-sm font-bold text-gray-600">
              Usualmente los últimos 6 dígitos.
            </p>
          </div>

          <button
            type="submit"
            id="btn-submit"
            class="mt-4 w-full bg-[#d7fd48] border-4 border-black p-5 font-black text-2xl uppercase tracking-widest flex justify-center items-center gap-3 hover:-translate-y-2 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] active:translate-y-0 active:shadow-none transition-all"
          >
            <span class="material-symbols-outlined font-black">send</span>
            ENVIAR RECARGA A REVISIÓN
          </button>
        </form>
      </section>

      <!-- PANEL DERECHO: INFO & INSTRUCCIONES -->
      <aside class="w-full lg:w-96 flex flex-col gap-6">
        <div
          class="bg-black text-white border-4 border-black p-6 shadow-[6px_6px_0px_0px_#d7fd48]"
        >
          <h3
            class="text-xl font-black uppercase mb-4 text-[#d7fd48] flex items-center gap-2"
          >
            <span class="material-symbols-outlined">help_center</span> INSTRUCCIONES
          </h3>
          <ol class="flex flex-col gap-4 font-bold text-sm">
            <li class="flex gap-3">
              <span
                class="bg-[#8b5cf6] text-white w-6 h-6 flex justify-center items-center -full shrink-0 border-2 border-white"
                >1</span
              >
              <span
                >Realiza el Pago Móvil o transferencia a las cuentas
                autorizadas.</span
              >
            </li>
            <li class="flex gap-3">
              <span
                class="bg-[#8b5cf6] text-white w-6 h-6 flex justify-center items-center -full shrink-0 border-2 border-white"
                >2</span
              >
              <span
                >Llena el formulario con tus datos y la referencia exacta del
                pago.</span
              >
            </li>
            <li class="flex gap-3">
              <span
                class="bg-[#8b5cf6] text-white w-6 h-6 flex justify-center items-center -full shrink-0 border-2 border-white"
                >3</span
              >
              <span
                >Un administrador validará la transacción y se te acreditarán
                los fondos y <strong>+10 XP</strong>.</span
              >
            </li>
          </ol>
        </div>

        <div
          class="bg-white border-4 border-black p-6 shadow-[6px_6px_0px_0px_#8b5cf6]"
        >
          <h3
            class="text-xl font-black uppercase mb-4 text-black border-b-4 border-black pb-2"
          >
            Cuentas Autorizadas
          </h3>
          <div class="flex flex-col gap-3 font-bold text-sm">
            <div class="p-3 bg-[#f4f4f5] border-2 border-black">
              <p class="text-[#8b5cf6] uppercase mb-2">Banesco (Pago Móvil)</p>
              <div class="flex items-center justify-between mb-1">
                <p>CI: <span class="copy-val">V-30000000</span></p>
                <button
                  type="button"
                  class="copy-btn bg-black text-white hover:bg-[#d7fd48] hover:text-black border-2 border-black p-1 transition-colors flex items-center justify-center"
                  aria-label="Copiar CI"
                >
                  <span class="material-symbols-outlined text-[14px]"
                    >content_copy</span
                  >
                </button>
              </div>
              <div class="flex items-center justify-between">
                <p>Tlf: <span class="copy-val">0414-1234567</span></p>
                <button
                  type="button"
                  class="copy-btn bg-black text-white hover:bg-[#d7fd48] hover:text-black border-2 border-black p-1 transition-colors flex items-center justify-center"
                  aria-label="Copiar Teléfono"
                >
                  <span class="material-symbols-outlined text-[14px]"
                    >content_copy</span
                  >
                </button>
              </div>
            </div>
            <div class="p-3 bg-[#f4f4f5] border-2 border-black">
              <p class="text-[#8b5cf6] uppercase mb-2">
                Mercantil (Transferencia)
              </p>
              <div class="flex items-center justify-between mb-1">
                <p>
                  Nro: <span class="copy-val">0105-0000-00-0000000000</span>
                </p>
                <button
                  type="button"
                  class="copy-btn bg-black text-white hover:bg-[#d7fd48] hover:text-black border-2 border-black p-1 transition-colors flex items-center justify-center"
                  aria-label="Copiar Número"
                >
                  <span class="material-symbols-outlined text-[14px]"
                    >content_copy</span
                  >
                </button>
              </div>
              <div class="flex items-center justify-between">
                <p>CI: <span class="copy-val">V-30000000</span></p>
                <button
                  type="button"
                  class="copy-btn bg-black text-white hover:bg-[#d7fd48] hover:text-black border-2 border-black p-1 transition-colors flex items-center justify-center"
                  aria-label="Copiar CI"
                >
                  <span class="material-symbols-outlined text-[14px]"
                    >content_copy</span
                  >
                </button>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</MainLayout>

<!-- NEBRUTALIST TOAST CONTAINER (si no está global) -->
<div
  id="toast-container"
  class="fixed top-5 right-5 z-9999 flex flex-col gap-3 pointer-events-none"
>
</div>

<style>
  /* Brutalist base styles applied inline mostly, keeping it contained */
</style>

<script>
  import { fetchAPI } from "../../services/api.js";

  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("recarga-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
      "btn-submit",
    ) as HTMLButtonElement;
    const montoBsInput = document.getElementById(
      "monto_bs",
    ) as HTMLInputElement;
    const montoCapyPreview = document.getElementById(
      "monto-capy-preview",
    ) as HTMLElement;

    // Simulador visual de tasa
    let tasaDolar = 45; // Default fallback

    // Conseguir tasa real
    fetchAPI("/tasa")
      .then((res) => {
        if (res && res.tasa) tasaDolar = res.tasa;
      })
      .catch((err) => console.log("Error cargando tasa en recargas", err));

    // Copiar a portapapeles
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const val =
          (target.parentElement?.querySelector(".copy-val") as HTMLElement)
            ?.innerText || "";
        navigator.clipboard.writeText(val);
        showBrutalistToast("¡COPIADO: " + val + "!", "success");
      });
    });

    montoBsInput.addEventListener("input", (e) => {
      const bs = parseFloat((e.target as HTMLInputElement).value) || 0;
      const capys = bs / tasaDolar;
      if (bs > 0) {
        montoCapyPreview.innerHTML = `Monto estimado en capys (tasa ${tasaDolar}): <span class="text-xl md:text-2xl text-[#8b5cf6] font-black inline-block ml-2 px-2 bg-white border-2 border-black animate-pulse shadow-[2px_2px_0px_#000]">${capys.toFixed(2)}</span>`;
      } else {
        montoCapyPreview.innerHTML = "Monto estimado en capys: 0.00";
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (submitBtn.disabled) return;

      const cedula = (
        document.getElementById("cedula") as HTMLInputElement
      ).value.trim();
      const monto_bs = parseFloat(montoBsInput.value);
      const metodo_pago = (
        document.getElementById("metodo_pago") as HTMLSelectElement
      ).value;
      const reference_number = (
        document.getElementById("reference_number") as HTMLInputElement
      ).value.trim();

      if (!cedula || monto_bs <= 0 || !metodo_pago || !reference_number) {
        showBrutalistToast(
          "POR FAVOR COMPLETA TODOS LOS CAMPOS CORRECTAMENTE",
          "error",
        );
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML =
        '<span class="material-symbols-outlined font-black animate-spin">sync</span> CARGANDO...';
      submitBtn.classList.add("opacity-70", "cursor-not-allowed");

      try {
        // SIMULACIÓN PARA PRUEBAS
        let response: any = {};
        try {
          response = await fetchAPI("/transacciones/recargar", {
            method: "POST",
            body: JSON.stringify({
              cedula,
              monto_bs,
              metodo_pago,
              reference_number,
            }),
          });

          if (response.error) {
            console.warn(
              "Error del backend ignorado para probar interfaz:",
              response.error,
            );
          }
        } catch (err) {
          console.warn("Backend catch ignorado:", err);
        }

        form.reset();
        montoCapyPreview.innerHTML = "Monto estimado en capys: 0.00";
        showBrutalistToast(
          "¡RECARGA ENVIADA A REVISIÓN! +10 XP CUANDO SEA APROBADA 🐹",
          "success",
        );
        setTimeout(() => {
          window.location.href = "/finance/history";
        }, 3000);
      } catch (error: any) {
        showBrutalistToast(
          error.message || "ERROR AL CONECTAR CON EL SERVIDOR",
          "error",
        );
        submitBtn.disabled = false;
        submitBtn.innerHTML =
          '<span class="material-symbols-outlined font-black">send</span> ENVIAR RECARGA A REVISIÓN';
        submitBtn.classList.remove("opacity-70", "cursor-not-allowed");
      }
    });

    function showBrutalistToast(message: string, type: string = "success") {
      const container = document.getElementById("toast-container");
      if (!container) return alert(message);

      const isError = type === "error";
      const bgColor = isError ? "bg-[#ff3333]" : "bg-[#d7fd48]";
      const textColor = isError ? "text-white" : "text-black";
      const shadowColor = isError
        ? "shadow-[4px_4px_0px_0px_#000]"
        : "shadow-[6px_6px_0px_0px_#000]";

      const toast = document.createElement("div");
      toast.className = `max-w-xs ${bgColor} ${textColor} border-4 border-black p-4 font-black ${shadowColor} uppercase tracking-widest transform transition-all duration-300 translate-x-full`;
      toast.innerHTML = `<p>${message}</p>`;

      container.appendChild(toast);

      // Animación de entrada
      setTimeout(() => toast.classList.remove("translate-x-full"), 50);

      // Desaparecer luego de 4s
      setTimeout(() => {
        toast.classList.add("translate-x-full");
        setTimeout(() => toast.remove(), 300);
      }, 4000);
    }
  });
</script>
