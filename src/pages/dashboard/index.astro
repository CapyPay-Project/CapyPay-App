---
import CapyPay from "../../layouts/MainLayout.astro";
import { NivelBadge } from "../../components/ui/index";
import UserWalletBalance from "../../components/dashboard/finance/UserWalletBalance.astro";
import QuickActionsPanel from "../../components/dashboard/actions/QuickActionsPanel.astro";
import CashFlowAnalytics from "../../components/dashboard/analytics/CashFlowAnalytics.astro";
import BcvTickerPanel from "../../components/dashboard/finance/BcvTickerPanel.astro";
import MissionsWidget from "../../components/dashboard/gamification/MissionsWidget.astro";
import MissionsModal from "../../components/dashboard/gamification/MissionsModal.astro";
---

<CapyPay title="Dashboard | CapyPay" showSidebar={true}>
  <div class="flex flex-col lg:h-full w-full pb-20 lg:pb-0">
    <!-- HEADER ESCRITORIO -->
    <header
      class="hidden lg:flex justify-between items-end mb-8 animate-fade-in-down relative z-50"
    >
      <div>
        <h1
          class="text-4xl md:text-5xl font-black text-black uppercase tracking-tighter leading-none"
        >
          CENTRO DE COMANDOS
        </h1>
        <p
          class="text-[#8b5cf6] font-black tracking-widest text-[10px] sm:text-xs mt-2 uppercase"
        >
          FINANCIAL PROTOCOL V.2.04
        </p>
      </div>
      <div class="flex gap-4 items-center">
        <!-- Notificaciones Popover -->
        <div class="relative" id="notif-dropdown-container">
          <button
            onclick="const nm=document.getElementById('notif-menu'); nm.classList.toggle('hidden'); nm.classList.toggle('flex');"
            class="w-12 h-12 bg-white border-4 border-black box-shadow-brutal flex items-center justify-center hover:translate-y-1 hover:shadow-none transition-all relative focus:outline-none"
          >
            <span class="material-symbols-outlined font-black text-xl"
              >notifications</span
            >
            <span
              id="mobile-notif-badge"
              class="absolute -top-2 -right-2 bg-[#d7fd48] text-black border-2 border-black text-[9px] font-black px-1.5 py-0.5"
              style="display:none;">0</span
            >
          </button>

          <!-- Dropdown Menu -->
          <div
            id="notif-menu"
            class="hidden absolute right-0 top-full mt-2 w-72 bg-white border-4 border-black box-shadow-brutal z-50 flex-col"
          >
            <div
              class="border-b-4 border-black p-3 font-black uppercase text-sm bg-[#d7fd48]"
            >
              Notificaciones
            </div>
            <div
              id="notif-menu-list"
              class="max-h-64 overflow-y-auto flex flex-col p-2 gap-2 empty:p-4 empty:text-center empty:text-gray-500 empty:uppercase empty:text-xs"
            >
              <!-- Cargadas por JS -->
              <p class="text-xs text-center font-bold">Cargando...</p>
            </div>
            <a
              href="/account/notifications"
              class="block w-full border-t-4 border-black p-3 text-center bg-[#8b5cf6] text-white font-black uppercase text-xs hover:bg-[#7c3aed] transition-colors"
            >
              VER TODAS
            </a>
          </div>
        </div>

        <a
          href="/account/profile"
          class="flex gap-3 bg-white border-4 border-black box-shadow-brutal px-3 py-2 items-center hover:translate-y-1 hover:shadow-none transition-all cursor-pointer"
        >
          <div
            class="w-8 h-8 bg-black overflow-hidden flex items-center justify-center"
          >
            <span class="material-symbols-outlined text-white text-sm"
              >person</span
            >
          </div>
          <div class="flex flex-col">
            <span class="text-xs font-black uppercase" id="desktop-username"
              >USER_092</span
            >
            <span
              class="text-[9px] font-bold text-gray-500 uppercase tracking-widest"
              >VERIFICADO</span
            >
          </div>
        </a>
      </div>
    </header>

    <!-- HEADER MOVIL -->
    <div
      class="flex items-center justify-between lg:hidden mb-6 animate-fade-in-down"
    >
      <div class="flex flex-col">
        <h1
          class="text-3xl font-black text-black uppercase tracking-tighter leading-none"
        >
          COMMAND CENTER
        </h1>
        <p
          class="text-[#8b5cf6] font-black tracking-widest text-[9px] mt-1 uppercase"
        >
          V.2.04
        </p>
      </div>
      <button
        id="mobile-logout-btn"
        class="w-10 h-10 bg-white border-4 border-black box-shadow-brutal flex items-center justify-center"
      >
        <span class="material-symbols-outlined font-black">logout</span>
      </button>
    </div>

    <!-- MAIN GRID 12 COLS -->
    <div class="grid lg:grid-cols-12 gap-6 items-stretch flex-1 min-h-0">
      <!-- LEFT SECTION (9 COLS) -->
      <div
        class="lg:col-span-8 xl:col-span-9 flex flex-col gap-6 animate-fade-in-up"
      >
        <!-- Balance Row -->
        <div class="w-full">
          <UserWalletBalance amount="0.00" />
        </div>

        <!-- Middle Row (Chart + QuickPay) -->
        <div class="grid lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2">
            <CashFlowAnalytics />
          </div>
          <div class="lg:col-span-1">
            <QuickActionsPanel />
          </div>
        </div>

        <!-- Bottom Row (Exchange, Tasks, Level) -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="h-32 sm:h-auto">
            <BcvTickerPanel />
          </div>

          <!-- Daily Tasks Widget -->
          <MissionsWidget />

          <!-- User Level Widget -->
          <div
            class="bg-[#deb2ff] border-4 border-black box-shadow-brutal p-4 sm:p-5 flex flex-col justify-between items-center text-center h-32 sm:h-full group hover:-translate-y-1 transition-transform"
          >
            <div class="w-full flex justify-between items-start">
              <span
                class="material-symbols-outlined text-3xl transition-transform group-hover:scale-110"
                >military_tech</span
              >
              <span
                class="bg-white border-2 border-black px-2 py-0.5 text-[10px] font-black"
                >NIVEL</span
              >
            </div>
            <div class="mt-2 text-center w-full">
              <p
                class="font-black text-[10px] uppercase text-black tracking-widest mb-1 text-center w-full"
              >
                NIVEL
              </p>
              <h3 class="font-black text-3xl uppercase leading-none" id="user-level">1</h3>
              <div class="w-full bg-white border-2 border-black h-2 mt-1">
                <div class="bg-[#8b5cf6] h-full transition-all duration-300" id="level-progress" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT SECTION (FLUJO RECIENTE) (3 COLS) -->
      <div
        class="lg:col-span-4 xl:col-span-3 bg-white border-4 border-black box-shadow-brutal flex flex-col h-full max-h-full animate-fade-in-left overflow-hidden"
      >
        <!-- Header -->
        <div
          class="p-5 border-b-4 border-black flex flex-col sm:flex-row justify-between items-center shrink-0 bg-white z-10 w-full text-center lg:text-left gap-2"
        >
          <h2 class="text-xl font-black text-black uppercase tracking-widest">
            HISTORIAL
          </h2>
          <div
            class="flex border-2 border-black text-[10px] font-black uppercase"
          >
            <button
              id="btn-hist-expenses"
              class="px-2 py-1 bg-white text-black hover:bg-gray-200 transition-colors"
              >Egresos</button
            >
            <button
              id="btn-hist-income"
              class="px-2 py-1 bg-white text-black hover:bg-gray-200 transition-colors"
              >Ingresos</button
            >
          </div>
        </div>

        <!-- List container -->
        <div
          id="history-list-container"
          class="flex-1 overflow-y-auto p-4 custom-scrollbar bg-white"
        >
          <p
            class="text-center text-gray-500 font-bold text-sm mt-10 uppercase"
          >
            Cargando...
          </p>
        </div>
      </div>
    </div>
  </div>

  <MissionsModal />

  <!-- MODAL XP GANADO -->
  <div
    id="xp-modal"
    class="fixed inset-0 z-60 hidden items-center justify-center bg-black/30 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300"
    aria-hidden="true"
  >
    <div
      class="bg-[#d7fd48] border-4 border-black w-full max-w-xs rounded-lg p-6 relative text-center transform scale-95 transition-all duration-300"
      role="dialog"
      aria-modal="true"
      aria-label="XP Ganado"
    >
      <div class="flex flex-col items-center">
        <div class="w-16 h-16 bg-black border-4 border-[#d7fd48] rounded-full flex items-center justify-center mb-4 animate-bounce">
          <span class="text-2xl font-black text-[#d7fd48]">⭐</span>
        </div>
        <h3 class="text-xl font-black uppercase tracking-wider text-black mb-2">¡XP Ganado!</h3>
        <p id="xp-amount" class="text-3xl font-black text-black mb-4">+10 XP</p>
        <button
          onclick="window.closeXpModal()"
          class="bg-black text-[#d7fd48] border-2 border-black px-4 py-2 font-black uppercase hover:bg-gray-800 transition"
        >
          ¡Genial!
        </button>
      </div>
    </div>
  </div>

  <!-- MODAL CERRAR SESION -->
  <div
    id="logout-modal"
    class="fixed inset-0 z-100 hidden items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"
  >
    <div
      class="bg-white border-4 border-black box-shadow-brutal w-full max-w-sm p-6 m-4 transform scale-95 transition-transform duration-300"
    >
      <h3 class="text-2xl font-black uppercase mb-2">¿CERRAR SESIÓN?</h3>
      <p class="font-bold text-gray-600 mb-6 uppercase text-sm">
        ¿Estás seguro de que quieres salir?
      </p>
      <div class="flex gap-4">
        <button
          id="cancel-logout"
          class="flex-1 border-4 border-black py-3 font-black uppercase hover:bg-gray-200 transition-colors"
          >NO</button
        >
        <button
          id="confirm-logout"
          class="flex-1 border-4 border-black bg-[#8b5cf6] text-white py-3 font-black uppercase hover:bg-[#7c3aed] transition-colors"
          >SÍ, SALIR</button
        >
      </div>
    </div>
  </div>

  <style>
    .box-shadow-brutal {
      box-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
    }
    @keyframes fadeInDown {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    @keyframes fadeInLeft {
      from {
        opacity: 0;
        transform: translateX(20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .animate-fade-in-down {
      animation: fadeInDown 0.4s ease-out forwards;
    }
    .animate-fade-in-up {
      animation: fadeInUp 0.4s ease-out forwards;
      opacity: 0;
      animation-delay: 0.1s;
    }
    .animate-fade-in-left {
      animation: fadeInLeft 0.4s ease-out forwards;
      opacity: 0;
      animation-delay: 0.2s;
    }

    /* Custom scrollbar for Recent Flow */
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: white;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: black;
    }
  </style>

  <script>
    // @ts-nocheck
    import {
      authService,
      userService,
      notificationService,
    } from "../../services/api.js";
    import { userProfile } from "../../store/userStore.js";

    let cachedMovements = [];
    let currentFilter = "all";

    function renderHistoryList() {
      const container = document.getElementById("history-list-container");
      if (!container) return;

      let filteredMoves = cachedMovements;
      if (currentFilter === "expenses") {
        filteredMoves = cachedMovements.filter((m) => m.es_negativo);
      } else if (currentFilter === "income") {
        filteredMoves = cachedMovements.filter((m) => !m.es_negativo);
      }

      const moves = filteredMoves.slice(0, 7);

      if (moves.length === 0) {
        container.innerHTML =
          '<p class="text-center font-bold text-gray-500 text-sm mt-10 uppercase">NO HAY MOVIMIENTOS</p>';
        return;
      }

      let html = '<div class="space-y-4">';

      moves.forEach((mov) => {
        const isNegative = mov.es_negativo;
        const amount = mov.monto;
        const displayAmount = isNegative ? `-$${amount}` : `+$${amount}`;
        const amountColor = isNegative ? "text-red-500" : "text-[#10b981]";

        const descString = (mov.descripcion || mov.concept || mov.tipo || "").toLowerCase();
        let iconBg = "bg-white";
        let iconSvg =
          '<span class="material-symbols-outlined font-black">receipt_long</span>';

        if (
          descString.includes("comedor") ||
          descString.includes("canteen") ||
          descString.includes("bite")
        ) {
          iconBg = "bg-[#8b5cf6]";
          iconSvg =
            '<span class="material-symbols-outlined font-black text-white">lunch_dining</span>';
        } else if (
          descString.includes("scholarship") ||
          (!isNegative && descString.includes("deposit"))
        ) {
          iconBg = "bg-[#d7fd48]";
          iconSvg =
            '<span class="material-symbols-outlined font-black text-black">payments</span>';
        } else if (
          descString.includes("ticket") ||
          descString.includes("bus")
        ) {
          iconBg = "bg-[#8b5cf6]";
          iconSvg =
            '<span class="material-symbols-outlined font-black text-white">directions_bus</span>';
        } else if (
          descString.includes("press") ||
          descString.includes("book")
        ) {
          iconBg = "bg-black";
          iconSvg =
            '<span class="material-symbols-outlined font-black text-white">book</span>';
        }

        const dateObj = new Date(mov.fecha);
        const dateFull = dateObj.toLocaleDateString("en-US", {
          month: "short",
          day: "numeric",
        });
        const timeFull = dateObj.toLocaleTimeString("en-US", {
          hour: "2-digit",
          minute: "2-digit",
        });

        html += `
          <div class="flex items-center justify-between p-3 border-4 border-black group hover:-translate-y-1 transition-transform box-shadow-brutal cursor-pointer bg-white">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-12 h-12 border-2 border-black ${iconBg} flex items-center justify-center shrink-0">
                  ${iconSvg}
              </div>
              <div class="flex flex-col min-w-0">
                <h4 class="text-xs font-black text-black uppercase truncate leading-none mb-1">${mov.descripcion || mov.concept || mov.tipo}</h4>
                <p class="text-[9px] font-bold text-gray-500 uppercase tracking-widest">${dateFull}, ${timeFull}</p>
              </div>
            </div>
            <div class="font-black text-sm ${amountColor} whitespace-nowrap pl-2">
              ${displayAmount}
            </div>
          </div>`;
      });

      container.innerHTML = html + "</div>";
    }

    function renderNotificationBar(notifications) {
      const badge = document.getElementById('mobile-notif-badge');
      const notifMenuList = document.getElementById('notif-menu-list');
      const unread = notifications.filter((n) => !n.leida && !n.read && !n.is_read).length;

      if (badge) {
        if (unread > 0) {
          badge.innerText = unread > 9 ? '+9' : String(unread);
          badge.style.display = 'flex';
        } else {
          badge.style.display = 'none';
        }
      }

      if (!notifMenuList) return;

      if (notifications.length === 0) {
        notifMenuList.innerHTML = '<p class="text-xs text-center font-bold uppercase py-2">Sin notificaciones</p>';
        return;
      }

      notifMenuList.innerHTML = notifications
        .slice(0, 5)
        .map((n) => {
          const isUnread = !n.leida && !n.read && !n.is_read;
          const dateStr = new Date(n.created_at || n.fecha || Date.now()).toLocaleDateString('es-VE');
          return `
            <div class="border-2 border-black p-2 hover:bg-gray-100 transition-colors cursor-pointer ${isUnread ? 'bg-[#d7fd48]/20' : 'bg-white'}"
                 onclick="window.handleNotificationClick('${n.id || n._id}', ${isUnread})">
              <p class="text-[10px] font-black uppercase line-clamp-2 leading-tight">${n.message || 'Nueva notificación'}</p>
              <p class="text-[9px] text-gray-600 mt-1 uppercase">${dateStr}</p>
            </div>`;
        })
        .join('');
    }

    // Manejador para click en notificación del dropdown
    window.handleNotificationClick = async (notifId, isUnread) => {
      if (isUnread) {
        try {
          await notificationService.markAsRead(notifId);
          // Actualizar estado local y refrescar
          await refreshNotifications();
        } catch (e) {
          console.error("Error marcando notificación como leída:", e);
        }
      }
    };

    async function refreshNotifications() {
      try {
        const notifsRes = await notificationService.getNotifications();
        let notifs = [];
        if (Array.isArray(notifsRes)) notifs = notifsRes;
        else if (notifsRes && Array.isArray(notifsRes.notifications)) notifs = notifsRes.notifications;
        else if (notifsRes && Array.isArray(notifsRes.data)) notifs = notifsRes.data;
        renderNotificationBar(notifs);
      } catch (err) {
        console.error('Error actualizando notificaciones:', err);
      }
    }

    // end added notification helpers

    async function initDashboard() {
      const btnExpenses = document.getElementById("btn-hist-expenses");
      const btnIncome = document.getElementById("btn-hist-income");
      if (btnExpenses && btnIncome) {
        btnExpenses.onclick = () => {
          if (currentFilter === "expenses") {
            currentFilter = "all";
            btnExpenses.classList.replace("bg-black", "bg-white");
            btnExpenses.classList.replace("text-white", "text-black");
          } else {
            currentFilter = "expenses";
            btnExpenses.classList.replace("bg-white", "bg-black");
            btnExpenses.classList.replace("text-black", "text-white");
            btnIncome.classList.replace("bg-black", "bg-white");
            btnIncome.classList.replace("text-white", "text-black");
          }
          renderHistoryList();
        };
        btnIncome.onclick = () => {
          if (currentFilter === "income") {
            currentFilter = "all";
            btnIncome.classList.replace("bg-black", "bg-white");
            btnIncome.classList.replace("text-white", "text-black");
          } else {
            currentFilter = "income";
            btnIncome.classList.replace("bg-white", "bg-black");
            btnIncome.classList.replace("text-black", "text-white");
            btnExpenses.classList.replace("bg-black", "bg-white");
            btnExpenses.classList.replace("text-white", "text-black");
          }
          renderHistoryList();
        };
      }
      const user = authService.getCurrentUser();
      if (!user) {
        return;
      }

      // User name updater
      const updateName = (name) => {
        let u = name || "USUARIO";
        const desktopName = document.getElementById("desktop-username");
        if (desktopName) desktopName.innerText = u.split(" ")[0].toUpperCase();
      };

      if (user.nombre || user.name) {
        updateName(user.nombre || user.name);
      }

      // Logout Mobile
      const mobileLogout = document.getElementById("mobile-logout-btn");
      const logoutModal = document.getElementById("logout-modal");
      const confirmLogoutBtn = document.getElementById("confirm-logout");
      const cancelLogoutBtn = document.getElementById("cancel-logout");

      window.showLogoutModal = () => {
        if (typeof window.openLogoutModal === "function") {
          window.openLogoutModal();
          return;
        }
        logoutModal.classList.remove("hidden");
        logoutModal.classList.add("flex");
        requestAnimationFrame(() => {
          logoutModal.classList.remove("opacity-0");
          logoutModal.querySelector("div").classList.remove("scale-95");
          logoutModal.querySelector("div").classList.add("scale-100");
        });
      };

      window.closeLogoutModal = () => {
        if (!logoutModal) return;
        logoutModal.classList.add("opacity-0");
        logoutModal.querySelector("div").classList.add("scale-95");
        logoutModal.querySelector("div").classList.remove("scale-100");
        setTimeout(() => {
          logoutModal.classList.add("hidden");
          logoutModal.classList.remove("flex");
        }, 300);
      };

      const missionsModal = document.getElementById("missions-modal");
      const missionsList = document.getElementById("missions-list");
      const missionsCounter = document.getElementById("missions-counter");
      const missionsProgress = document.getElementById("missions-progress");

      window.showMissionsModal = async () => {
        console.log('showMissionsModal called');
        if (!missionsModal) {
          console.log('missionsModal not found');
          return;
        }
        const currentUser = authService.getCurrentUser();
        if (!currentUser?.id) {
          console.warn('Usuario no autenticado para misiones');
          return;
        }

        console.log('Fetching missions for user:', currentUser.id);
        try {
          const res = await fetch(`/api/missions/user/${currentUser.id}`);
          console.log('Fetch response status:', res.status);
          const body = await res.json();
          console.log('Fetch response body:', body);
          const { missions = [] } = body;
          console.log('Missions array:', missions);
          console.log('First mission item:', missions[0]);

          if (missionsList) {
            if (missions.length === 0) {
              missionsList.innerHTML = '<p class="text-sm text-center">No hay misiones disponibles.</p>';
            } else {
              let completed = 0;
              missionsList.innerHTML = missions.map((item) => {
                const target = item.missions?.target_count ?? item.target_count ?? 1;
                const progress = item.progress ?? 0;
                const percent = Math.min(100, Math.round((progress / target) * 100));
                if (item.completed) completed += 1;

                return `
                <div class="border-2 border-black bg-white p-3 rounded-lg">
                  <div class="flex justify-between items-center">
                    <p class="font-black text-xs uppercase tracking-wider">${item.missions?.title || 'Misión'}</p>
                    <span class="text-[10px] font-black ${item.completed ? 'text-green-700' : 'text-gray-600'}">${item.completed ? 'COMPLETADA' : 'EN PROCESO'}</span>
                  </div>
                  <p class="text-[10px] text-gray-600 mt-1">${item.missions?.description || 'Descripción no disponible'}</p>
                  <div class="w-full bg-black/10 h-2 rounded-full mt-2 overflow-hidden border-2 border-black">
                    <div class="h-full bg-[#8b5cf6]" style="width: ${percent}%"></div>
                  </div>
                  <p class="text-[10px] font-black mt-1">${progress} / ${target} · +${item.missions?.xp_reward ?? item.xp_reward ?? 0} XP</p>
                  <div class="mt-2 flex justify-end">
                    ${item.completed
                      ? '<span class="inline-block px-2 py-1 text-[10px] font-black uppercase text-white bg-green-700 rounded">Completada</span>'
                      : `<button class="px-2 py-1 text-[10px] font-black uppercase bg-[#d7fd48] border-2 border-black rounded hover:bg-[#cde439] transition" onclick="window.completeMission('${item.missions?.code ?? item.code}')">Avanzar misión</button>`
                    }
                  </div>
                </div>`;
              }).join('');

              if (missionsCounter) {
                missionsCounter.textContent = `${completed}/${missions.length} Completadas`;
              }
              if (missionsProgress) {
                missionsProgress.style.width = `${missions.length > 0 ? Math.round((completed / missions.length) * 100) : 0}%`;
              }
            }
          }
        } catch (err) {
          console.error('Error cargando misiones:', err);
          // Mock data for testing
          const missions = [
            { mission: { title: 'Recargar tu saldo', description: 'Realiza una recarga en tu saldo Capy.', target_count: 1, xp_reward: 10 }, progress: 0, completed: false },
            { mission: { title: 'Enviar saldo a otro usuario', description: 'Envía saldo a otro usuario CapyPay.', target_count: 1, xp_reward: 5 }, progress: 0, completed: false },
            { mission: { title: 'Comprar en el comedor', description: 'Realiza una compra en el comedor.', target_count: 1, xp_reward: 10 }, progress: 0, completed: false }
          ];
        }

        console.log('Showing modal');
        missionsModal.classList.remove('hidden');
        missionsModal.classList.add('flex');
        requestAnimationFrame(() => {
          missionsModal.classList.remove('opacity-0');
          const modalBox = missionsModal.querySelector('div');
          console.log('modalBox:', modalBox);
          if (modalBox) {
            modalBox.classList.remove('scale-95');
            modalBox.classList.add('scale-100');
            modalBox.classList.remove('opacity-0');
          }
        });
      };

      window.completeMission = async (missionCode) => {
        const user = authService.getCurrentUser();
        if (!user?.id || !missionCode) return;

        try {
          const response = await fetch('/api/missions/complete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: user.id, missionCode })
          });

          if (!response.ok) {
            const err = await response.json();
            console.error('Error completando misión:', err);
            return;
          }

          const result = await response.json();
          console.log('Misión actualizada:', result);
          if (window.showToast) {
            window.showToast(`Misión '${missionCode}' actualizada`, 'success', 'Misión completada');
          }
          await refreshNotifications();
          await window.showMissionsModal();
        } catch (error) {
          console.error('Error en completeMission:', error);
          if (window.showToast) {
            window.showToast('Error al completar misión', 'error');
          }
        }
      };

      window.closeMissionsModal = () => {
        if (!missionsModal) return;
        missionsModal.classList.add('opacity-0');
        const modalBox = missionsModal.querySelector('div');
        if (modalBox) {
          modalBox.classList.add('scale-95');
          modalBox.classList.remove('scale-100');
          modalBox.classList.add('opacity-0');
        }
        setTimeout(() => {
          missionsModal.classList.add('hidden');
          missionsModal.classList.remove('flex');
        }, 300);
      };

      if (missionsModal) {
        missionsModal.addEventListener('click', (e) => {
          if (e.target === missionsModal) {
            window.closeMissionsModal();
          }
        });
      }

      if (mobileLogout) mobileLogout.onclick = window.showLogoutModal;
      if (cancelLogoutBtn) cancelLogoutBtn.onclick = window.closeLogoutModal;
      if (confirmLogoutBtn) {
        confirmLogoutBtn.onclick = () => {
          authService.logout();
          window.location.href = "/login";
        };
      }

      window.addEventListener("logout-requested", window.showLogoutModal);

      // Fetch
      try {
        const userInfo = await userService.getProfile();

        await refreshNotifications();

        document.addEventListener("click", (e) => {
          const container = document.getElementById("notif-dropdown-container");
          const menu = document.getElementById("notif-menu");
          if (container && menu && !container.contains(e.target)) {
            menu.classList.add("hidden");
            menu.classList.remove("flex");
          }
        });

        try {
          const histRes = await userService.getHistory(userInfo.cedula);
          if (Array.isArray(histRes)) cachedMovements = histRes;
          else if (histRes && Array.isArray(histRes.movimientos))
            cachedMovements = histRes.movimientos;
          else if (histRes && Array.isArray(histRes.data))
            cachedMovements = histRes.data;
          else cachedMovements = [];

          renderHistoryList();
        } catch (e) {
          const container = document.getElementById("history-list-container");
          if (container)
            container.innerHTML =
              '<p class="text-center font-bold text-red-500 text-sm mt-10 uppercase">ERROR AL CARGAR</p>';
        }
      } catch (err) {
        console.error("DEBUG DASH:", err);
        const c = document.getElementById("history-list-container");
        if (c)
          c.innerHTML =
            '<p class="text-center font-bold text-red-500 text-sm mt-10 uppercase">ERROR INIT: ' +
            err.message +
            "</p>";
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initDashboard);
    } else {
      initDashboard();
    }

    // Suscribirse al store de usuario para actualizar nivel
    userProfile.subscribe((profile) => {
      const levelEl = document.getElementById("user-level");
      const progressEl = document.getElementById("level-progress");
      if (levelEl) levelEl.textContent = profile.level || 1;
      if (progressEl) progressEl.style.width = `${profile.progress || 0}%`;
    });
  </script>
</CapyPay>
