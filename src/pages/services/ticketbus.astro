---
import MainLayout from "../../layouts/MainLayout.astro";

const precioPasaje = 5.00;
const paradasUNERG = ["Terminal", "La Redoma", "Plaza Bolívar", "UNERG Entrada", "Área de Salud", "Ingeniería"];
const rutasRecientes = ["Ingeniería", "Terminal"]; // Las que aparecerán en el nuevo botón
---

<MainLayout title="Ticket Bus | CapyPay">
  <div class="flex flex-col gap-6 h-full p-4 lg:p-0">
    
    <div class="bg-brand-black p-6 rounded-3xl border border-white/10 shadow-lg relative overflow-hidden group">
      <div class="relative z-10 flex gap-4 items-center w-full">
        <a href="/dashboard" class="flex items-center justify-center w-12 h-12 rounded-full bg-white/5 hover:bg-white/10 text-white border border-white/10 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </a>
        <div class="w-16 h-16 rounded-full bg-brand-purple/20 flex items-center justify-center text-brand-purple border border-brand-purple/30">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h8a2 2 0 012 2v10a2 2 0 01-2 2H8a2 2 0 01-2-2V9a2 2 0 012-2zM6 13h12M7 17h.01M17 17h.01" />
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-white mb-1">Ticket Bus</h1>
          <p class="text-slate-400 text-sm">San Juan de los Morros - UNERG</p>
        </div>
      </div>
    </div>

    <div class="bg-brand-black p-6 rounded-3xl border border-white/10 shadow-lg relative overflow-hidden">
      <div class="flex flex-col relative z-10">
       <span class="text-slate-400 text-sm uppercase mb-1 font-bold tracking-wider">Tu saldo actual:</span>
        <div class="flex items-baseline gap-2">
          <span id="ticketbus-balance" class="text-5xl font-bold text-brand-lime font-monaco">0.00</span>
         <span class="text-slate-400 text-lg font-bold">BARAS</span>
       </div>
      </div>
    </div>

    <div class="bg-brand-black p-6 rounded-3xl border border-white/10 shadow-lg flex flex-col gap-4">
      <div class="relative">
        <p class="text-slate-500 text-xs uppercase tracking-widest mb-2 font-bold">Ruta General</p>
        <button id="btn-rutas" class="w-full flex justify-between items-center bg-white/5 p-5 rounded-2xl border border-white/10 hover:border-brand-lime/50 transition-all text-white font-bold text-lg">
          <span id="ruta-seleccionada">Selecciona tu parada</span>
          <svg xmlns="http://www.w3.org/2000/svg" id="icono-flecha-rutas" class="h-6 w-6 text-brand-lime transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div id="lista-paradas" class="hidden absolute z-30 w-full mt-2 bg-slate-900/80 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl max-h-60 overflow-y-auto">
         {paradasUNERG.map((parada) => (
          <button class="opcion-parada w-full p-4 text-left hover:bg-brand-lime/10 border-b border-white/5 text-slate-200 transition-colors">
            {parada}
          </button>
        ))}
        </div>
      </div>

      <div class="relative mt-2">
        <p class="text-slate-500 text-xs uppercase tracking-widest mb-2 font-bold">Accesos Rápidos</p>
        <button id="btn-recientes" class="w-full flex justify-between items-center bg-brand-purple/10 p-5 rounded-2xl border border-brand-purple/30 hover:bg-brand-purple/20 hover:border-brand-purple transition-all text-white font-bold text-lg animate-pulse hover:animate-none">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-purple" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span id="texto-reciente">Rutas Recientes</span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" id="icono-flecha-recientes" class="h-6 w-6 text-brand-purple transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div id="lista-recientes" class="hidden absolute z-30 w-full mt-2 bg-slate-900/80 backdrop-blur-xl border border-brand-purple/30 rounded-2xl shadow-2xl max-h-60 overflow-y-auto">
          {rutasRecientes.map((reciente) => (
          <button class="opcion-reciente w-full p-4 text-left hover:bg-brand-purple/10 border-b border-white/5 text-brand-purple transition-colors font-medium">
            {reciente}
          </button>
          ))}
        </div>
      </div>

      <div class="relative group mt-4">
        <div class="absolute -inset-1 bg-liner-to-r from-brand-lime to-emerald-400 rounded-2xl blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
        
        <button 
          id="btn-pagar" 
          type="button"
          class="relative w-full py-5 rounded-2xl font-black text-xl bg-brand-lime text-black flex items-center justify-center gap-3 shadow-[0_10px_20px_rgba(163,230,53,0.3)] hover:shadow-brand-lime/50 hover:-translate-y-1 active:translate-y-0.5 active:scale-95 transition-all duration-300 overflow-hidden"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
          </svg>
          
          <span id="texto-btn-pagar" class="tracking-tight">GENERAR TICKET QR</span>

          <div class="absolute top-0 -inset-full h-full w-1/2 z-5 block transform -skew-x-12 bg-linear-to-r from-transparent via-white/40 to-transparent opacity-40 group-hover:animate-shine"></div>
        </button>
      </div>
    </div>
  </div>

<div id="modal-qr" class="hidden fixed inset-0 z-50 items-center justify-center p-4 bg-black/90 backdrop-blur-md">
  <div class="bg-brand-black border border-white/10 p-8 rounded-[2.5rem] max-w-sm w-full text-center shadow-[0_0_50px_rgba(163,230,53,0.1)] flex flex-col items-center">
    
    <div class="w-12 h-1 bg-white/10 rounded-full mb-6"></div> <h2 class="text-white text-2xl font-black mb-2 tracking-tight">¡VIAJE LISTO!</h2>
    <p class="text-slate-400 text-sm mb-8">Muestra este código al chofer del bus</p>
    
    <div class="bg-white p-5 rounded-4xl shadow-2xl mb-8 transform hover:scale-105 transition-transform duration-300">
      <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=CapyPay-Ticket-UNERG" alt="QR Ticket" class="w-48 h-48" />
    </div>

    <div class="bg-white/5 border border-white/5 py-3 px-6 rounded-2xl mb-8">
       <p id="info-ticket" class="text-brand-lime font-mono text-xl font-bold uppercase tracking-widest"></p>
    </div>

    <button id="btn-cerrar-qr" class="w-full py-4 bg-white/5 text-slate-300 rounded-2xl hover:bg-purple-500/20 hover:text-purple-500 border border-white/5 transition-all font-bold">
      CERRAR TICKET
    </button>
  </div>
</div>

<style>
  @keyframes shine {
    100% {
      left: 125%;
    }
  }
  .group-hover\:animate-shine:hover {
    animation: shine 0.8s;
  }
</style>

</MainLayout>

<script>

  // @ts-nocheck
  import { userProfile, fetchUserProfile } from "../../store/userStore.js";

  function procesarPago(monto) {
    const perfilActual = userProfile.get();
    if (perfilActual.balance >= monto) {
      userProfile.set({
        ...perfilActual,
        balance: perfilActual.balance - monto
      });
      return true;
    }
    return false;
  }

  fetchUserProfile();

// Variable para guardar el saldo anterior y saber desde dónde empezar el conteo
  let saldoAnterior = 0;

  userProfile.subscribe((profile) => {
    const balanceEl = document.getElementById("ticketbus-balance");
    
    if (balanceEl && !profile.isLoading) {
      const saldoFinal = profile.balance || 0;
      
      // Si el saldo cambió, hacemos la animación
      if (saldoFinal !== saldoAnterior) {
        animateNumber(balanceEl, saldoAnterior, saldoFinal, 1000); // 1000ms = 1 segundo de duración
        saldoAnterior = saldoFinal;
      }
    }
  });

  // Función mágica para animar el número
  function animateNumber(element, start, end, duration) {
    let startTime = null;

    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      const progress = Math.min((timestamp - startTime) / duration, 1);
      const current = progress * (end - start) + start;
      
      element.innerText = current.toLocaleString("en-US", { 
        minimumFractionDigits: 2, 
        maximumFractionDigits: 2 
      });

      if (progress < 1) {
        window.requestAnimationFrame(step);
      }
    }
    window.requestAnimationFrame(step);
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Referencias al Menú Principal (Verde)
    const btnRutas = document.getElementById('btn-rutas');
    const listaParadas = document.getElementById('lista-paradas');
    const textoRuta = document.getElementById('ruta-seleccionada');
    const flechaRutas = document.getElementById('icono-flecha-rutas');
    const opcionesParada = document.querySelectorAll('.opcion-parada');
    
    // Referencias al Menú Recientes (Morado)
    const btnRecientes = document.getElementById('btn-recientes');
    const listaRecientes = document.getElementById('lista-recientes');
    const textoReciente = document.getElementById('texto-reciente');
    const flechaRecientes = document.getElementById('icono-flecha-recientes');
    const opcionesReciente = document.querySelectorAll('.opcion-reciente');

    // Referencias de Pago
    const btnPagar = document.getElementById('btn-pagar');
    const textoBtnPagar = document.getElementById('texto-btn-pagar');
    const modalQr = document.getElementById('modal-qr');
    const btnCerrarQr = document.getElementById('btn-cerrar-qr');
    const infoTicket = document.getElementById('info-ticket');

    // 1. Lógica del Menú Principal
    btnRutas?.addEventListener('click', () => {
      listaParadas?.classList.toggle('hidden');
      flechaRutas?.classList.toggle('rotate-180');
      // Cerrar el otro menú por si está abierto
      listaRecientes?.classList.add('hidden');
      flechaRecientes?.classList.remove('rotate-180');
    });

    opcionesParada.forEach(opcion => {
      opcion.addEventListener('click', () => {
        if(textoRuta) textoRuta.innerText = opcion.innerText;
        listaParadas?.classList.add('hidden');
        flechaRutas?.classList.remove('rotate-180');
        // Resetear el otro menú
        if(textoReciente) textoReciente.innerText = "Rutas Recientes";
      });
    });

    // 2. Lógica del Menú Recientes
    btnRecientes?.addEventListener('click', () => {
      listaRecientes?.classList.toggle('hidden');
      flechaRecientes?.classList.toggle('rotate-180');
      // Cerrar el menú principal por si está abierto
      listaParadas?.classList.add('hidden');
      flechaRutas?.classList.remove('rotate-180');
    });

    opcionesReciente.forEach(opcion => {
      opcion.addEventListener('click', () => {
        const rutaElegida = opcion.innerText;
        if(textoReciente) textoReciente.innerText = rutaElegida;
        listaRecientes?.classList.add('hidden');
        flechaRecientes?.classList.remove('rotate-180');
        // Poner la misma ruta en el principal
        if(textoRuta) textoRuta.innerText = rutaElegida;
      });
    });

    // 3. Lógica del Botón Pagar
    btnPagar?.addEventListener('click', () => {
      const ruta = textoRuta?.innerText;
      
      if (ruta === "Selecciona tu parada" || ruta === "Rutas Recientes") {
        alert("¡Paola, elige una parada primero! 😊");
        return;
      }

      // Animación de "Procesando"
      if (textoBtnPagar) textoBtnPagar.innerText = "PROCESANDO...";
      if (window.navigator.vibrate) window.navigator.vibrate(50);
      
      setTimeout(() => {
        if (textoBtnPagar) textoBtnPagar.innerText = "GENERAR TICKET QR";
        
        // Intentar Cobrar
        // Definimos los sonidos (puedes cambiarlos por otros enlaces .mp3 si quieres)
        const sonidoExito = new Audio('https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3'); // Sonido de moneda/pago
        const sonidoError = new Audio('https://assets.mixkit.co/active_storage/sfx/253/253-preview.mp3');   // Sonido de error/alerta
        if (procesarPago(5.00)) {
           // ¡SUENA EL DINERO! 💰
        sonidoExito.play(); 
  
       if (infoTicket) infoTicket.innerText = ruta;
           modalQr?.classList.remove('hidden');
           modalQr?.classList.add('flex');
        } else {
        // ¡SUENA EL ERROR! ❌
        sonidoError.play();
          // Error visual si no hay saldo
          const balanceContainer = document.getElementById('ticketbus-balance')?.parentElement?.parentElement;
          if (balanceContainer) {
            balanceContainer.classList.add('animate-bounce');
            document.getElementById('ticketbus-balance').classList.replace('text-brand-lime', 'text-red-500');
            
            setTimeout(() => {
              balanceContainer.classList.remove('animate-bounce');
              document.getElementById('ticketbus-balance').classList.replace('text-red-500', 'text-brand-lime');
            }, 1000);
          }
          alert("¡Paola, te quedaste sin BARAS! 💸");
        }
      }, 600);
    });

    // 4. Cerrar QR
    btnCerrarQr?.addEventListener('click', () => {
      modalQr?.classList.add('hidden');
      modalQr?.classList.remove('flex');
    });
  });
</script>