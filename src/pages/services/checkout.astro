---
import MainLayout from "../../layouts/MainLayout.astro";
import { cartItems, clearCart } from "../../store/cartStore";
// Import transaction service if strictly needed server side?
// Actually, transactionService is likely a client-side module if it uses fetch globally or similar.
// But we are using it inside the script tag.
---

<MainLayout title="Resumen de Pago | CapyPay" showSidebar={true}>
  <div
    class="max-w-2xl mx-auto p-4 md:p-8"
    style="font-family: 'Space Grotesk', sans-serif;"
  >
    <a
      href="/services/comedor"
      class="inline-flex w-max items-center gap-2 text-black bg-white hover:bg-[#d7fd48] transition-colors mb-6 group font-black uppercase tracking-wider text-sm border-[3px] border-black px-4 py-2 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-none"
    >
      <svg
        class="w-5 h-5 group-hover:-translate-x-1 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="3"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
      >
      VOLVER AL MENÚ
    </a>

    <h1
      class="text-4xl md:text-6xl font-black text-black uppercase tracking-tighter mb-8 drop-shadow-[2px_2px_0px_white]"
    >
      RESUMEN DEL PEDIDO
    </h1>

    <div class="grid gap-8">
      <!-- Order Items -->
      <div
        class="bg-white border-[4px] border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-6 md:p-8 relative"
      >
        <h2
          class="absolute -top-4 left-6 bg-[#8CFFE1] border-[3px] border-black px-4 py-1 text-xl font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transform -rotate-2"
        >
          Detalle de items
        </h2>
        <div id="checkout-items" class="grid grid-cols-1 gap-4 mb-8 mt-6">
          <!-- Fallback content, will be replaced by JS -->
          <div
            class="animate-pulse flex items-center gap-4 border-[3px] border-black p-3"
          >
            <div class="w-16 h-16 bg-gray-200 border-[3px] border-black"></div>
            <div class="flex-1 space-y-2">
              <div class="h-4 bg-gray-200 border-2 border-black w-1/2"></div>
              <div class="h-3 bg-gray-200 border-2 border-black w-1/4"></div>
            </div>
          </div>
        </div>

        <!-- Summary Lines -->
        <div
          class="border-t-[4px] border-black pt-6 space-y-3 mb-6 bg-gray-50 p-4"
        >
          <div
            class="flex justify-between text-lg font-bold uppercase tracking-wide text-black"
          >
            <span>Subtotal</span>
            <span id="checkout-subtotal">0 BARAS</span>
          </div>
          <div
            class="flex justify-between text-lg font-bold uppercase tracking-wide text-black"
          >
            <span>Comisión (5%)</span>
            <span id="checkout-fee">0 BARAS</span>
          </div>
        </div>

        <div
          class="bg-black text-white p-4 border-[4px] border-black shadow-[6px_6px_0px_0px_rgba(215,253,73,1)] flex justify-between items-center transform rotate-1"
        >
          <span class="font-black text-xl uppercase">Total a pagar</span>
          <span id="checkout-total" class="text-3xl font-black text-[#d7fd48]"
            >0 BARAS</span
          >
        </div>
      </div>

      <!-- Payment Action -->
      <div
        class="bg-white border-[4px] border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] p-6 md:p-8 relative mt-4"
      >
        <h2
          class="absolute -top-4 right-6 bg-[#d7fd48] border-[3px] border-black px-4 py-1 text-xl font-black uppercase shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transform rotate-2"
        >
          Método de Pago
        </h2>

        <!-- Opciones de Pago Interactivos -->
        <div class="flex flex-col gap-4 mt-6 mb-8 payment-methods-container">
          <label class="cursor-pointer group">
            <input
              type="radio"
              name="payment_method"
              value="wallet"
              class="peer sr-only payment-radio"
            />
            <div
              class="flex items-center justify-between gap-4 bg-white peer-checked:bg-black peer-checked:text-white border-[3px] border-black p-4 transition-all duration-300 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 group-hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] peer-checked:shadow-[6px_6px_0px_0px_rgba(215,253,73,1)]"
            >
              <div class="flex items-center gap-4">
                <!-- Radio dot -->
                <div
                  class="w-6 h-6 rounded-none border-[3px] border-black bg-white flex items-center justify-center shrink-0"
                >
                  <div
                    class="w-3 h-3 bg-[#d7fd48] border-[3px] border-black rounded-none scale-0 peer-checked:scale-100 transition-transform duration-200"
                  >
                  </div>
                </div>
                <div
                  class="w-12 h-12 bg-[#8CFFE1] flex items-center justify-center text-black border-[3px] border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transform -rotate-6 shrink-0 group-hover:rotate-0 transition-transform"
                >
                  <span class="material-symbols-outlined font-black"
                    >wallet</span
                  >
                </div>
                <div>
                  <h4 class="font-black text-xl uppercase tracking-tighter">
                    Saldo CapyPay
                  </h4>
                  <p
                    class="font-bold text-gray-500 peer-checked:text-gray-300 uppercase text-[10px]"
                  >
                    Pago instantáneo
                  </p>
                </div>
              </div>
            </div>
          </label>

          <label class="cursor-pointer group">
            <input
              type="radio"
              name="payment_method"
              value="card"
              class="peer sr-only payment-radio"
            />
            <div
              class="flex items-center justify-between gap-4 bg-white peer-checked:bg-black peer-checked:text-white border-[3px] border-black p-4 transition-all duration-300 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 group-hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] peer-checked:shadow-[6px_6px_0px_0px_rgba(215,253,73,1)]"
            >
              <div class="flex items-center gap-4">
                <!-- Radio dot -->
                <div
                  class="w-6 h-6 rounded-none border-[3px] border-black bg-white flex items-center justify-center shrink-0"
                >
                  <div
                    class="w-3 h-3 bg-[#d7fd48] border-[3px] border-black rounded-none scale-0 peer-checked:scale-100 transition-transform duration-200"
                  >
                  </div>
                </div>
                <div
                  class="w-12 h-12 bg-[#E4C1F9] flex items-center justify-center text-black border-[3px] border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transform rotate-3 shrink-0 group-hover:rotate-0 transition-transform"
                >
                  <span class="material-symbols-outlined font-black"
                    >point_of_sale</span
                  >
                </div>
                <div>
                  <h4 class="font-black text-xl uppercase tracking-tighter">
                    Tarjeta / Pago Móvil
                  </h4>
                  <p
                    class="font-bold text-gray-500 peer-checked:text-gray-300 uppercase text-[10px]"
                  >
                    Paga en caja
                  </p>
                </div>
              </div>
            </div>
          </label>
        </div>

        <button
          id="do-payment-btn"
          disabled
          class="w-full py-4 bg-gray-300 text-gray-500 pointer-events-none font-black uppercase text-2xl border-[4px] border-black transition-all shadow-none flex items-center justify-center gap-3 relative overflow-hidden group data-[active=true]:bg-[#8b5cf6] data-[active=true]:hover:bg-[#d7fd48] data-[active=true]:hover:text-black data-[active=true]:text-white data-[active=true]:pointer-events-auto data-[active=true]:active:translate-y-1 data-[active=true]:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] data-[active=true]:hover:shadow-none"
        >
          <span class="relative z-10 flex items-center gap-2">
            Confirmar Pago
            <svg
              class="w-6 h-6 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="3"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path></svg
            >
          </span>
        </button>
      </div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    import { cartItems, clearCart } from "../../store/cartStore";
    import { authService, comedorService, fetchAPI } from "../../services/api";
    import { showToast } from "../../utils/toast";

    function initCheckoutLogic() {
      const itemsContainer = document.getElementById("checkout-items");
      const subtotalEl = document.getElementById("checkout-subtotal");
      const feeEl = document.getElementById("checkout-fee");
      const totalEl = document.getElementById("checkout-total");
      const payBtn = document.getElementById("do-payment-btn"); // Removed TS casting

      if (!itemsContainer || !totalEl || !payBtn) return;

      const radios = document.querySelectorAll(".payment-radio");
      radios.forEach((r) => {
        r.addEventListener("change", () => {
          if (r.checked) {
            payBtn.removeAttribute("disabled");
            payBtn.setAttribute("data-active", "true");
            payBtn.classList.remove(
              "bg-gray-300",
              "text-gray-500",
              "pointer-events-none",
              "shadow-none",
            );
          }
        });
      });

      // 1. Logic for Price Sync & Rendering
      async function initCheckout() {
        let items = cartItems.get();
        let itemsArray = Object.values(items).filter(
          (i) => i.type === "comedor" || !i.type,
        );

        if (itemsArray.length === 0) {
          // If cart is empty, go back to previous page or a default
          window.location.href = "/services/comedor";
          return;
        }

        // --- PRICE SYNC START ---
        try {
          const CACHE_KEY = "capypay_menu_cache_v3";
          // 7 Days validation (Matches Comedor)
          const CACHE_DURATION = 7 * 24 * 60 * 60 * 1000;
          let menuData = null;

          // 1. Try Cache
          const cached = localStorage.getItem(CACHE_KEY);
          if (cached) {
            const parsed = JSON.parse(cached);
            if (Date.now() - parsed.timestamp < CACHE_DURATION) {
              menuData = parsed.data;
              console.log("Checkout: Using cached prices");
            }
          }

          // 2. Refresh Cache if needed (Once a week or initial load)
          if (!menuData) {
            console.log("Checkout: Refreshing prices from API...");
            menuData = await fetchAPI("/comedor/menu");
            if (menuData) {
              localStorage.setItem(
                CACHE_KEY,
                JSON.stringify({
                  timestamp: Date.now(),
                  data: menuData,
                }),
              );
            }
          }

          // 3. Update Cart Prices
          if (menuData) {
            const priceMap = new Map();
            // Flatten all possible sources
            if (menuData.platoDia)
              priceMap.set(
                String(menuData.platoDia.id),
                parseFloat(menuData.platoDia.price),
              );
            if (menuData.popularItems)
              menuData.popularItems.forEach((i) =>
                priceMap.set(String(i.id), parseFloat(i.price)),
              );
            if (menuData.items)
              menuData.items.forEach((i) =>
                priceMap.set(String(i.id), parseFloat(i.price)),
              );

            let pricesUpdated = false;

            itemsArray.forEach((item) => {
              const freshPrice = priceMap.get(String(item.id));
              // Only update if fresh price exists and is different
              // If fresh price is missing (e.g. item removed from menu), we keep old price or warn?
              // For now, keep old price to avoid breaking UI, user will get error on buy if actually invalid.
              if (
                freshPrice !== undefined &&
                freshPrice !== parseFloat(item.price)
              ) {
                console.warn(
                  `Updating price for ${item.name}: ${item.price} -> ${freshPrice}`,
                );
                item.price = freshPrice;
                pricesUpdated = true;
                // Persist to store logic
                cartItems.setKey(item.id, { ...item, price: freshPrice });
              }
            });

            if (pricesUpdated) {
              items = cartItems.get(); // Refresh local reference
              itemsArray = Object.values(items);
              showToast("⚠️ Precios actualizados al valor actual", "info");
            }
          }
        } catch (e) {
          console.error("Price Sync Error:", e);
          // Fail gracefully, use existing cart prices
        }
        // --- PRICE SYNC END ---

        renderItems(itemsArray);
      }

      function renderItems(itemsArray) {
        let subtotal = 0;

        // Render items
        itemsContainer.innerHTML = itemsArray
          .map((item) => {
            const itemTotal = item.price * item.quantity;
            subtotal += itemTotal;
            return `
                    <div class="flex justify-between items-center bg-gray-50 border-[3px] border-black p-4 mb-2">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-[#d7fd48] flex items-center justify-center text-black font-black text-sm border-[3px] border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
                                x${item.quantity}
                            </div>
                            <div class="flex flex-col">
                                <h4 class="text-black font-black uppercase text-sm md:text-base text-balance leading-tight">${item.name}</h4>
                                <span class="text-[10px] md:text-xs text-black/60 font-bold uppercase tracking-wider mt-1">Unitario: ${item.price} BARAS</span>
                            </div>
                        </div>
                        <span class="text-black font-black text-sm md:text-lg">${itemTotal.toLocaleString()} BARAS</span>
                    </div>
                `;
          })
          .join("");

        // Calculate totals
        const commission = Math.round(subtotal * 0.05); // 5% Simulation
        const totalAmount = subtotal + commission;

        if (subtotalEl)
          subtotalEl.textContent = `${subtotal.toLocaleString()} BARAS`;
        if (feeEl) feeEl.textContent = `${commission.toLocaleString()} BARAS`;
        totalEl.textContent = `${totalAmount.toLocaleString()} BARAS`;

        // Store total in memory for logic usage? No need, recalculated on backend.
      }

      // Run Init
      initCheckout();

      // 2. Lógica de Pago
      payBtn.addEventListener("click", async () => {
        // Refresh items from store to get latest state
        const currentItems = Object.values(cartItems.get());
        const btn = payBtn;
        const originalText = btn.innerHTML;

        try {
          btn.disabled = true;
          btn.innerHTML = `<span class="animate-spin h-5 w-5 border-2 border-white border-t-transparent -full mr-2"></span> Procesando...`;

          const userStr = localStorage.getItem("capypay_user");
          if (!userStr) throw new Error("Debes iniciar sesión");
          const user = JSON.parse(userStr);

          // Validar identificador de usuario
          const userId = user.id || user.usuarioId;
          if (!userId)
            throw new Error("ID de usuario no encontrado en sesión local");

          // CALCULAR TOTAL LOCALMENTE PARA VALIDACIÓN PREVIA
          const totalLocal = currentItems.reduce(
            (acc, item) => acc + parseFloat(item.price) * item.quantity,
            0,
          );
          const commissionLocal = Math.round(totalLocal * 0.05);
          const grandTotal = totalLocal + commissionLocal;

          const userBalance = parseFloat(user.balance || 0);

          if (userBalance < grandTotal) {
            throw new Error(
              `Saldo insuficiente. Tienes ${userBalance.toFixed(2)} pero necesitas ${grandTotal.toFixed(2)}.`,
            );
          }

          // Determine if order is for Comedor or Cantina
          // We can guess by checking if the items have a 'cantina_id' or by checking the URL they came from.
          // Since our current cart implementation doesn't store 'type', we'll check if the item has `priceCapys` (Cantina) or relies purely on `price`.
          // For a robust solution, we assume if ANY item is from a Cantina (we can check by checking the API error or by adding a flag).
          // Let's add a heuristic: Cantina items have UUIDs as IDs, Comedor items usually have INTEGER IDs.
          const validItems = currentItems.filter(
            (i) => i.type === "comedor" || !i.type,
          );
          const orderItems = validItems.map((item) => ({
            id: item.id,
            quantity: item.quantity,
            price: item.price,
          }));

          const response = await comedorService.createOrder(userId, orderItems);

          if (!response) throw new Error("Error al crear la orden");

          showToast(
            response.message || "¡Pago realizado con éxito!",
            "success",
          );

          // Clear cart
          clearCart("comedor");

          // Redirect to Receipt page
          // response usually contains { message, orderId, newBalance, xpGained }
          if (response.orderId) {
            window.location.href = `/services/order?id=${response.orderId}`;
          } else {
            // Fallback if no specific order ID (should not happen with new logic)
            window.location.href = "/finance/history";
          }
        } catch (error) {
          console.error("Payment Error:", error);
          showToast(error.message || "Error al procesar el pago", "error");
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      });
    }

    // Initialize Page Logic
    document.addEventListener("astro:page-load", initCheckoutLogic);

    // Fallback for non-ViewTransitions
    if (
      document.readyState === "complete" ||
      document.readyState === "interactive"
    ) {
      initCheckoutLogic();
    }
  </script>
</MainLayout>
