---
import MainLayout from "../../layouts/MainLayout.astro";
import { cartItems, clearCart } from "../../store/cartStore";
// Import transaction service if strictly needed server side?
// Actually, transactionService is likely a client-side module if it uses fetch globally or similar.
// But we are using it inside <script> tag.
---

<MainLayout title="Pago de Cantina | CapyPay" showSidebar={true}>
  <div class="max-w-2xl mx-auto p-4 md:p-8">
    <a
      href="javascript:history.back()"
      class="inline-flex items-center gap-2 text-white/50 hover:text-white mb-6"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
      >
      Volver al menú
    </a>

    <h1 class="text-3xl font-extrabold text-white mb-8">Resumen del Pedido</h1>

    <div class="grid gap-8">
      <!-- Order Items -->
      <div class="bg-[#1a1a1a] border-4 border-black -3xl p-6">
        <h2 class="text-lg font-bold text-white mb-4">Detalle de items</h2>
        <div
          id="checkout-items"
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-4"
        >
          <!-- Fallback content, will be replaced by JS -->
          <div class="animate-pulse flex items-center gap-4">
            <div class="w-16 h-16 bg-white border-2 border-black -xl"></div>
            <div class="flex-1 space-y-2">
              <div class="h-4 bg-white border-2 border-black  w-1/2"></div>
              <div class="h-3 bg-white border-2 border-black  w-1/4"></div>
            </div>
          </div>
        </div>

        <!-- Summary Lines -->
        <div class="border-t border-black pt-4 space-y-2 mb-4">
          <div class="flex justify-between text-sm">
            <span class="text-white/60">Subtotal</span>
            <span id="checkout-subtotal" class="text-white font-bold"
              >0.00 BARAS</span
            >
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-white/60">Comisión (5%)</span>
            <span id="checkout-fee" class="text-white/80">0.00 BARAS</span>
          </div>
        </div>

        <div
          class="border-t border-dashed border-black pt-4 flex justify-between items-end"
        >
          <span class="text-white/60">Total a pagar</span>
          <span id="checkout-total" class="text-3xl font-black text-brand-lime"
            >0.00 BARAS</span
          >
        </div>
      </div>

      <!-- Payment Action -->
      <div class="bg-white border-4 border-black -3xl p-6">
        <h2 class="text-lg font-bold text-white mb-2">Método de Pago</h2>
        <div
          class="flex items-center gap-4 bg-white border-4 border-black p-4 -xl mb-6"
        >
          <div
            class="w-10 h-10 -full bg-brand-lime flex items-center justify-center text-black"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
            >
          </div>
          <div>
            <h4 class="text-white font-bold">Saldo CapyPay</h4>
            <p class="text-white/50 text-xs">Pago instantáneo sin comisiones</p>
          </div>
        </div>

        <button
          id="do-payment-btn"
          class="w-full py-4 bg-brand-purple hover:bg-brand-purple/90 text-white font-extrabold -xl transition-all active:scale-95 flex items-center justify-center gap-2 relative overflow-hidden group"
        >
          <span class="relative z-10 flex items-center gap-2">
            Confirmar Pago
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
          </span>
          <div
            class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
          >
          </div>
        </button>
      </div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    import { cartItems, clearCart } from "../../store/cartStore";
    import { authService, cantinaService, fetchAPI } from "../../services/api";
    import { showToast } from "../../utils/toast";
    import { userProfile, updateUserLevel } from "../../store/userStore";

    function initCheckoutLogic() {
      const itemsContainer = document.getElementById("checkout-items");
      const subtotalEl = document.getElementById("checkout-subtotal");
      const feeEl = document.getElementById("checkout-fee");
      const totalEl = document.getElementById("checkout-total");
      const payBtn = document.getElementById("do-payment-btn"); // Removed TS casting

      let currentSubtotal = 0;
      let currentDiscountRate = 0;
      let currentDiscountAmount = 0;
      let currentServiceFee = 0;
      let currentGrandTotal = 0;

      if (!itemsContainer || !totalEl || !payBtn) return;

      // 1. Logic for Price Sync & Rendering
      async function initCheckout() {
        let items = cartItems.get();
        let itemsArray = Object.values(items).filter(i => i.type === 'cantina' || (i.id.toString().includes('-') && i.id.toString().length > 10));

        if (itemsArray.length === 0) {
          // If cart is empty, go back to previous page or a default
          window.location.href = "/services/cantina";
          return;
        }

        // We skip strict price sync here for simplicity and rely on the Backend to validate prices during checkout.
        renderItems(itemsArray);
      }

      function renderItems(itemsArray) {
        let subtotal = 0;
        const levelDiscountRate = Number(userProfile.get()?.benefits?.descuento || 0);

        // Render items
        itemsContainer.innerHTML = itemsArray
          .map((item) => {
            const itemTotal = item.price * item.quantity;
            subtotal += itemTotal;
            return `
                    <div class="flex justify-between items-center bg-white border-2 border-black p-3 -xl border-4 border-black">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10  bg-black/20 flex items-center justify-center text-white/50 font-bold text-xs border-4 border-black">
                                x${item.quantity}
                            </div>
                            <div class="flex flex-col">
                                <h4 class="text-white font-bold text-sm text-balance">${item.name}</h4>
                                <span class="text-[10px] text-white/40">Unitario: $${item.price}</span>
                            </div>
                        </div>
                        <span class="text-white font-bold text-sm text-brand-lime">${itemTotal.toLocaleString()} BARAS</span>
                    </div>
                `;
          })
          .join("");

        // Calculate totals
        const discountAmount = Number((subtotal * levelDiscountRate).toFixed(2));
        const discountedSubtotal = Number(Math.max(0, subtotal - discountAmount).toFixed(2));
        const commission = Number((discountedSubtotal * 0.05).toFixed(2));
        const totalAmount = Number((discountedSubtotal + commission).toFixed(2));

        currentSubtotal = subtotal;
        currentDiscountRate = levelDiscountRate;
        currentDiscountAmount = discountAmount;
        currentServiceFee = commission;
        currentGrandTotal = totalAmount;

        if (subtotalEl)
          subtotalEl.textContent = `${subtotal.toFixed(2)} BARAS`;
        if (feeEl) {
          feeEl.textContent = `Desc. ${Math.round(levelDiscountRate * 100)}%: -${discountAmount.toFixed(2)} | Servicio (5%): ${commission.toFixed(2)} BARAS`;
        }
        totalEl.textContent = `${totalAmount.toFixed(2)} BARAS`;

        // Store total in memory for logic usage? No need, recalculated on backend.
      }

      // Run Init
      initCheckout();

      // 2. Lógica de Pago
      payBtn.addEventListener("click", async () => {
        // Refresh items from store to get latest state
        const currentItems = Object.values(cartItems.get());
        const btn = payBtn;
        const originalText = btn.innerHTML;

        try {
          btn.disabled = true;
          btn.innerHTML = `<span class="animate-spin h-5 w-5 border-2 border-white border-t-transparent -full mr-2"></span> Procesando...`;

          const userStr = localStorage.getItem("capypay_user");
          if (!userStr) throw new Error("Debes iniciar sesión");
          const user = JSON.parse(userStr);

          // Validar identificador de usuario
          const userId = user.id || user.usuarioId;
          if (!userId)
            throw new Error("ID de usuario no encontrado en sesión local");

          // Filtrar unicamente items de cantina
          const validItems = currentItems.filter(i => i.type === 'cantina' || (i.id.toString().includes('-') && i.id.toString().length > 10));

          if (validItems.length === 0) {
            throw new Error("No hay productos válidos de cantina en tu carrito.");
          }

          // CALCULAR TOTAL LOCALMENTE PARA VALIDACIÓN PREVIA
          const totalLocal = validItems.reduce(
            (acc, item) => acc + parseFloat(item.price) * item.quantity,
            0,
          );

          // Mantener sincronía con visual de checkout (descuento por nivel + servicio)
          const levelDiscountRate = Number(userProfile.get()?.benefits?.descuento || 0);
          const discountLocal = Number((totalLocal * levelDiscountRate).toFixed(2));
          const discountedSubtotalLocal = Number(Math.max(0, totalLocal - discountLocal).toFixed(2));
          const commissionLocal = Number((discountedSubtotalLocal * 0.05).toFixed(2));
          const grandTotal = Number((discountedSubtotalLocal + commissionLocal).toFixed(2));

          const userBalance = parseFloat(user.balance || 0);

          if (userBalance < grandTotal) {
            throw new Error(
              `Saldo insuficiente. Tienes ${userBalance.toFixed(2)} pero necesitas ${grandTotal.toFixed(2)}.`,
            );
          }

          // Determine if order is for Comedor or Cantina
          // We can guess by checking if the items have a 'cantina_id' or by checking the URL they came from.
          // Since our current cart implementation doesn't store 'type', we'll check if the item has `priceCapys` (Cantina) or relies purely on `price`.
          // For a robust solution, we assume if ANY item is from a Cantina (we can check by checking the API error or by adding a flag).
          // Let's add a heuristic: Cantina items have UUIDs as IDs, Comedor items usually have INTEGER IDs.
          // Temp workaround: Find cantina_id by scanning products
          const productId = validItems[0].id;
          const tempCantinaReq = await fetchAPI(`/cantinas`);
          let cantinaId = null;
          if (tempCantinaReq && tempCantinaReq.cantinas) {
             tempCantinaReq.cantinas.forEach(c => {
               const pMatch = c.products.find(p => String(p.id) === String(productId));
               if (pMatch) cantinaId = c.id;
             });
          }

          if (!cantinaId) throw new Error("No se pudo identificar a qué cantina pertenece el producto.");

          // 4. Transformar items al formato del backend
          const cantinaItems = validItems.map(item => ({
            product_id: item.id,
            quantity: item.quantity
          }));

          const response = await cantinaService.purchaseProducts(
            userId, 
            cantinaId, 
            cantinaItems, 
            totalLocal, // total_bs (dummy values if we only use capys)
            grandTotal, // total_capys
            Math.ceil(grandTotal * 0.1) // total_xp
          );

          if (!response) throw new Error("Error al crear la orden de cantina");

          showToast(response.message || "¡Pago realizado con éxito!", "success");

          if (response?.pricing?.discountAmount > 0) {
            showToast(
              `Descuento aplicado: -${Number(response.pricing.discountAmount).toFixed(2)} BARAS`,
              "success",
            );
          }

          const userRaw = localStorage.getItem("capypay_user");
          if (userRaw) {
            try {
              const parsedUser = JSON.parse(userRaw);
              if (response?.newBalance !== undefined) parsedUser.balance = response.newBalance;
              if (response?.xpGained !== undefined) parsedUser.xp = Number(parsedUser.xp || 0) + Number(response.xpGained);
              localStorage.setItem("capypay_user", JSON.stringify(parsedUser));
            } catch (syncErr) {
              console.warn("No se pudo sincronizar capypay_user tras compra de cantina", syncErr);
            }
          }

          await updateUserLevel();

          // Clear cart
          clearCart("cantina");

          // Redirect to Receipt page
          // response usually contains { message, orderId, newBalance, xpGained }
          if (response.orderId) {
            window.location.href = `/services/order?id=${response.orderId}`;
          } else {
            // Fallback if no specific order ID (should not happen with new logic)
            window.location.href = "/finance/history";
          }
        } catch (error) {
          console.error("Payment Error:", error);
          showToast(error.message || "Error al procesar el pago", "error");
          btn.disabled = false;
          btn.innerHTML = originalText;
        }
      });
    }

    // Initialize Page Logic
    document.addEventListener("astro:page-load", initCheckoutLogic);

    // Fallback for non-ViewTransitions
    if (document.readyState === "complete" || document.readyState === "interactive") {
      initCheckoutLogic();
    }
  </script>
</MainLayout>
