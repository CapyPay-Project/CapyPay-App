---
import "../styles/landing.css";
import "../styles/parts/auth.css";
// Aquí podríamos inyectar scripts globales de la landing si hiciera falta
const { title = "CapyPay" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="landing-scope">
    <slot />
  </body>
</html>
