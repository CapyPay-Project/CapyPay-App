---
---

<div id="cantinas-view" class="hidden">
  <!-- Botón regresar a áreas -->
  <button
    id="back-to-areas"
    class="mb-4 sm:mb-6 flex items-center gap-2 text-slate-400 hover:text-brand-purple transition-colors font-medium text-sm sm:text-base"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-4 w-4 sm:h-5 sm:w-5"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 19l-7-7 7-7"
      ></path>
    </svg>
    Volver a áreas
  </button>

  <!-- Encabezado del área -->
  <div id="cantinas-header" class="bg-linear-to-br from-brand-lime/20 via-brand-purple/10 to-brand-black border border-brand-lime/30 -3xl p-4 sm:p-6 mb-8 relative overflow-hidden min-w-0">
    <div class="absolute -right-10 -top-10 w-40 h-40 bg-brand-lime/10 -full blur-3xl"></div>
    <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-brand-purple/10 -full blur-3xl"></div>
    <div class="relative z-10 min-w-0">
      <h2 id="area-title" class="text-xl sm:text-2xl md:text-3xl font-extrabold text-white mb-2 truncate"></h2>
      <div id="area-stats" class="text-white/60 text-xs sm:text-sm flex items-center gap-2">
        <span class="w-2 h-2 -full bg-brand-lime animate-pulse shrink-0"></span>
      </div>
    </div>
  </div>

   <!-- Lista de cantinas del área -->
   <div id="cantinas-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 min-w-0">
     <!-- Las tarjetas de cantinas se generan dinámicamente -->
   </div>
 </div>
