---
// User Level Widget - Neo Brutalist
---

<div class="bg-black border-4 border-black p-4 sm:p-5 box-shadow-brutal hover:-translate-y-1 transition-all rounded-2xl h-full flex flex-col justify-between" id="user-level-widget">
  <div class="flex justify-between items-start mb-2">
    <div class="bg-[#d7fd48] border-2 border-black p-2 rounded-xl flex items-center justify-center">
      <span class="material-symbols-outlined text-black font-bold">military_tech</span>
    </div>
    <span class="font-black text-[10px] uppercase border-2 border-black px-2 py-0.5 bg-[#8b5cf6] text-white rounded-lg" id="user-tier">
      CARGANDO...
    </span>
  </div>
  
  <div class="mt-auto">
    <h4 class="font-black uppercase tracking-tighter text-xs text-[#d7fd48]">Nivel de Usuario</h4>
    <div class="flex items-baseline gap-2 mt-1">
      <span class="font-black text-4xl sm:text-5xl tracking-tighter text-white" id="user-lvl">--</span>
      <span class="text-xs font-bold text-gray-400">/ 100</span>
    </div>
    
    <div class="mt-3 w-full bg-gray-800 border-2 border-black h-3 rounded-full overflow-hidden">
      <div id="user-progress" class="bg-[#d7fd48] h-full" style="width: 0%;"></div>
    </div>
    <div class="text-[9px] text-gray-400 font-bold uppercase mt-1 text-right" id="user-xp-text">0 / 0 XP</div>
  </div>
</div>

<style>
  .box-shadow-brutal {
    box-shadow: 4px 4px 0px 0px rgba(0,0,0,1);
  }
</style>

<script>
  import { authService, userService } from "../../../services/api.js";

  async function loadUserLevel() {
    try {
      const profile = await userService.getProfile();
      if (!profile) return;

      const lvlEl = document.getElementById("user-lvl");
      const tierEl = document.getElementById("user-tier");
      const progressEl = document.getElementById("user-progress");
      const xpTextEl = document.getElementById("user-xp-text");

      // Default values or from profile
      let levelNum = profile.nivel || Math.floor(Math.random() * 20) + 1;
      let exp = profile.exp || Math.floor(Math.random() * 900) + 100;
      let nextExp = (levelNum * 1000);
      let pct = (exp / nextExp) * 100;

      let tierName = "NOVATO";
      if(levelNum > 10) tierName = "BRONCE";
      if(levelNum > 20) tierName = "PLATA";
      if(levelNum > 30) tierName = "ORO";
      if(levelNum > 50) tierName = "DIAMANTE";

      if (lvlEl) lvlEl.innerText = levelNum;
      if (tierEl) tierEl.innerText = tierName;
      if (progressEl) progressEl.style.width = pct + "%";
      if (xpTextEl) xpTextEl.innerText = \`\${exp} / \${nextExp} XP\`;

    } catch (e) {
      console.warn("Failed to load user level");
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadUserLevel);
  } else {
    loadUserLevel();
  }
</script>
