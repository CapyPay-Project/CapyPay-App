---
// Neo-brutalist ExchangeRateWidget
---
<div class="h-full w-full bg-[#d7fd48] border-4 border-black hover:-translate-y-1 transition-all box-shadow-brutal p-4 sm:p-5 flex flex-col justify-between group cursor-default transition-all hover:bg-[#c2f01f]" id="exchange-rate-widget">
  <div class="w-full flex justify-between items-start">
    <span class="material-symbols-outlined text-3xl group-hover:rotate-180 transition-transform duration-500">currency_exchange</span>
    <span class="bg-white border-2 border-black px-2 py-0.5 text-[10px] font-black uppercase animate-pulse">EN VIVO</span>
  </div>

  <div class="mt-2 text-center w-full">
    <p class="font-black text-[10px] uppercase text-black tracking-widest mb-1 w-full text-center">TASA BCV</p>
    <div class="flex items-baseline justify-center gap-1">
      <span class="text-xl font-black">Bs.</span>
      <h2 id="bcv-rate-value" class="text-3xl font-black text-black leading-none">...</h2>
    </div>
  </div>
</div>

<style>
  .box-shadow-brutal {
    box-shadow: 4px 4px 0px 0px rgba(0,0,0,1);
  }
</style>

<script>
  import { transactionService } from "../../../services/api.js";

  async function updateRate() {
    try {
      const tasa = await transactionService.getRate();
      const rateEl = document.getElementById('bcv-rate-value');
      if (rateEl && tasa) {
        const valor = tasa.promedio || tasa.precio || tasa.monto || tasa.rate || tasa.tasa || "54.32";
        rateEl.innerText = parseFloat(valor).toFixed(2);
      }
    } catch (e) {
      console.error('Error cargando tasa', e);
      const rateEl = document.getElementById('bcv-rate-value');
      if (rateEl) rateEl.innerText = "54.32";
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', updateRate);
  } else {
    updateRate();
  }
</script>