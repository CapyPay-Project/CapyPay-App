---
const { nombre = "Bachiller", xp = 1500, icono = "🎓", id = null, extraClass = '' } = Astro.props;
---

<a href="/niveles" id={id} class={`nivel-badge bg-brand-black/80 backdrop-blur-md rounded-full px-2 sm:px-3 py-1 border border-white/10 flex items-center gap-1.5 sm:gap-2 hover:border-brand-lime/50 transition-all group ${extraClass}`} aria-label={`Ver niveles — ${nombre} — ${xp} XP`} title={`Ver niveles — ${nombre} — ${xp} XP`}>
  <span class="nivel-text text-brand-lime font-bold text-sm group-hover:scale-105 transition-transform">{icono} {nombre}</span>
  <svg class="w-3 h-3 text-slate-500 group-hover:text-brand-lime transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
  </svg>
</a>
