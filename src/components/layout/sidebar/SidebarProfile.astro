---
/**
 * SidebarProfile.astro
 * ─────────────────────────────────────────────────────────────────
 * Sección de perfil del usuario en la barra lateral.
 * Muestra la foto de perfil enlazada, nombre y barra de progreso XP.
 *
 * El contenido se rellena dinámicamente por el script de Sidebar.astro:
 *  - #sidebar-profile-photo  → borde de color según nivel
 *  - #sidebar-username       → nombre del usuario
 *  - #sidebar-level-text     → "Nivel Bachiller", etc.
 *  - #sidebar-level-xp       → XP actual
 *  - #sidebar-level-max      → XP máximo del nivel
 *  - #sidebar-level-bar      → ancho y color de la barra de progreso
 */
---

<div
  class="flex flex-col items-center p-2 py-4 border-b border-white/5 overflow-hidden whitespace-nowrap transition-all duration-300 origin-top"
>
  <!-- Foto de perfil (enlaza a la página de perfil) -->
  <a
    href="/account/profile"
    id="sidebar-profile-photo"
    class="w-9 h-9 rounded-full p-1 bg-transparent mb-2 transition-all duration-300 sidebar-photo border-2 hover:scale-105"
    title="Ver mi perfil"
  >
    <img
      src="https://api.dicebear.com/9.x/lorelei/svg?seed=Aneka"
      alt="Foto de perfil"
      class="w-full h-full rounded-full bg-black object-cover"
    />
  </a>

  <!-- Info expandida: nombre + barra XP (oculta cuando está colapsado) -->
  <div
    class="w-full flex flex-col items-center overflow-hidden transition-all duration-300 profile-content max-h-0 opacity-0"
  >
    <!-- Nombre de usuario -->
    <h3
      id="sidebar-username"
      class="text-white font-semibold text-base lg:text-lg mb-1"
    >
      Cargando...
    </h3>

    <!-- Barra de progreso de nivel/XP -->
    <div class="w-full mt-2">
      <div class="flex justify-between items-center text-xs text-slate-400 mb-1">
        <span id="sidebar-level-text" class="text-brand-lime font-bold">
          Nivel -
        </span>
      </div>
      <div
        class="flex justify-between items-center text-[10px] text-slate-500 mb-1"
      >
        <span id="sidebar-level-xp">0 XP</span>
        <span id="sidebar-level-max">0 XP</span>
      </div>
      <div class="w-full bg-slate-800 rounded-full h-1.5 overflow-hidden">
        <div
          id="sidebar-level-bar"
          class="bg-brand-lime h-full rounded-full w-[0%] shadow-[0_0_10px_rgba(215,253,72,0.5)]"
        >
        </div>
      </div>
    </div>
  </div>
</div>
