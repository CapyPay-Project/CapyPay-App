---
/**
 * SidebarFooter.astro
 * ─────────────────────────────────────────────────────────────────
 * Pie de la barra lateral con acciones secundarias.
 * El logout es manejado por el script de Sidebar.astro a través
 * del botón con id="desktop-logout-btn".
 *
 * Incluye:
 *  - Botón Compartir  → abre modal de compartir (futuro)
 *  - Botón Ajustes    → navega a /account/settings
 *  - Botón Salir      → llama a authService.logout() o showLogoutModal()
 */
---

<div
  class="p-4 border-t border-black mt-auto bg-black/50 flex flex-col gap-1 shrink-0"
>
  <!-- Botón Compartir -->
  <button
    class="flex items-center text-slate-400 hover:text-white hover:bg-white border-2 border-black p-2  transition-all group/share w-full text-left"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 shrink-0 group-hover/share:scale-110 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
      ></path>
    </svg>
    <span
      class="font-medium whitespace-nowrap sidebar-content opacity-0 pointer-events-none max-w-0 ml-0 overflow-hidden transition-all duration-500 ease-in-out"
      >Compartir</span
    >
  </button>

  <!-- Botón Ajustes -->
  <a
    href="/account/settings"
    class="flex items-center text-slate-400 hover:text-white hover:bg-white border-2 border-black p-2  transition-all group/settings w-full"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 shrink-0 group-hover/settings:rotate-90 transition-transform duration-500"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
      ></path>
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>
    <span
      class="font-medium whitespace-nowrap sidebar-content opacity-0 pointer-events-none max-w-0 ml-0 overflow-hidden transition-all duration-500 ease-in-out"
      >Ajustes</span
    >
  </a>

  <!-- Botón Cerrar Sesión (manejado por JS en Sidebar.astro) -->
  <a
    href="#"
    id="desktop-logout-btn"
    class="flex items-center text-red-400 hover:text-red-300 hover:bg-white border-2 border-black p-2  transition-all group/logout w-full"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 shrink-0 group-hover/logout:translate-x-1 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
      ></path>
    </svg>
    <span
      class="font-medium whitespace-nowrap sidebar-content opacity-0 pointer-events-none max-w-0 ml-0 overflow-hidden transition-all duration-500 ease-in-out"
      >Cerrar Sesión</span
    >
  </a>
</div>
