---
/**
 * Sidebar.astro
 * ─────────────────────────────────────────────────────────────────
 * Barra lateral de navegación principal (solo escritorio).
 * Se expande/colapsa con animación.
 *
 * Sub-componentes (en sidebar/):
 *  - SidebarNavItem  → elemento de navegación reutilizable
 *  - SidebarProfile  → foto, nombre y barra de XP del usuario
 *  - SidebarFooter   → botones de ajustes y cerrar sesión
 *
 * Script: carga de datos del usuario, polling de notificaciones
 * y lógica de expansión/colapso del sidebar.
 */
import Button from "../ui/Button.astro";
import SidebarNavItem from "./sidebar/SidebarNavItem.astro";
import SidebarProfile from "./sidebar/SidebarProfile.astro";
import SidebarFooter from "./sidebar/SidebarFooter.astro";

const currentPath = Astro.url.pathname;
---

<aside
  id="sidebar"
  class="group flex flex-col h-screen sticky top-0 z-50 transition-all duration-300 w-20 bg-[#0a0a0a] border-r border-white/10 shrink-0 overflow-hidden"
>
  <!-- Header: Logo, Collapse -->
  <div
    class="flex flex-col shrink-0 border-b border-white/5 transition-all duration-300 pb-2"
    id="headerSection"
  >
    <!-- Logo & Name -->
    <div
      class="h-16 flex items-center px-6 transition-all duration-300 w-full overflow-hidden whitespace-nowrap"
    >
      <div class="flex items-center transition-all duration-300">
        <div
          class="w-8 h-8 bg-brand-lime rounded-lg flex items-center justify-center text-black font-bold shadow-[0_0_15px_rgba(215,253,73,0.3)] shrink-0"
        >
          C
        </div>
        <span
          class="text-xl font-bold text-white sidebar-content opacity-0 pointer-events-none max-w-0 overflow-hidden ml-0 transition-all duration-500 ease-in-out"
        >
          CapyPay
        </span>
      </div>
    </div>

    <!-- Toggle Buttons -->
    <div
      class="w-full flex justify-center px-0 transition-all duration-300"
      id="toggleContainer"
    >
      <!-- Collapse Button -->
      <Button
        id="sidebarToggle"
        variant="icon"
        aria-label="Toggle Sidebar"
        class="text-slate-400 hover:text-white hover:bg-white/5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 transition-transform duration-300 rotate-180"
          id="toggleIcon"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
        </svg>
      </Button>
    </div>
  </div>

  <!-- ── Área scrollable (perfil + nav + contactos) ── -->
  <div
    class="flex-1 overflow-y-auto overflow-x-hidden custom-scrollbar scrollable-container"
  >
    <!-- Perfil: foto, nombre y barra de XP (datos inyectados por JS) -->
    <SidebarProfile />

    <!-- ── Navegación principal ── -->
    <div class="flex flex-col gap-1 px-3 mt-4 pb-4">
      <!-- Dashboard -->
      <SidebarNavItem
        href="/dashboard"
        label="Dashboard"
        currentPath={currentPath}
        title="Ir al Dashboard"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
          ></path>
        </svg>
      </SidebarNavItem>

      <!-- Historial de transacciones -->
      <SidebarNavItem
        href="/finance/history"
        label="Historial"
        currentPath={currentPath}
        title="Historial de Transacciones"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
          ></path>
        </svg>
      </SidebarNavItem>

      <!-- Pedidos (acción destacada en verde lima) -->
      <SidebarNavItem
        href="/services/orders"
        label="Pedidos"
        currentPath={currentPath}
        title="Mis Pedidos"
        highlight={true}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
          ></path>
        </svg>
      </SidebarNavItem>

      <!-- Contactos frecuentes -->
      <SidebarNavItem
        href="/account/contacts"
        label="Contactos"
        currentPath={currentPath}
        title="Contactos"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
      </SidebarNavItem>

      <!-- Niveles / Gamificación -->
      <SidebarNavItem
        href="/account/niveles"
        label="Niveles"
        currentPath={currentPath}
        title="Mis Niveles"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 19v-6a2 2 0 00-2 2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
          ></path>
        </svg>
      </SidebarNavItem>

      <!-- Notificaciones (con badge de conteo no leídas) -->
      <SidebarNavItem
        href="/account/notifications"
        label="Notificaciones"
        currentPath={currentPath}
        title="Notificaciones"
        badgeIconId="sidebar-notif-badge"
        badgeTextId="sidebar-notif-badge-text"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
          ></path>
        </svg>
      </SidebarNavItem>
    </div>

    <!-- Contacts Section (Frecuentes) -->
    <div
      class="flex-1 overflow-y-auto custom-scrollbar flex flex-col py-6 border-t border-white/5"
    >
      <!-- Search Bar -->
      <div class="px-3 mb-4">
        <button
          id="sidebar-search-trigger"
          class="w-full relative group/search"
        >
          <input
            id="sidebar-search-input"
            type="text"
            autocomplete="off"
            placeholder="Buscar..."
            class="bg-slate-800/50 text-slate-200 text-sm rounded-lg border-white/5 focus:outline-none focus:border-brand-lime/50 focus:bg-slate-800 transition-all placeholder:text-slate-500 w-0 p-0 border-0 opacity-0 pointer-events-none"
          />
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 text-slate-500 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none group-hover/search:text-brand-lime transition-colors"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
      </div>

      <!-- Contacts Title -->
      <div
        class="px-3 mb-2 sidebar-content opacity-0 pointer-events-none max-w-0 overflow-hidden ml-3 transition-all duration-500 ease-in-out"
      >
        <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest">
          Frecuentes
        </h4>
      </div>

      <div id="sidebar-contacts-list" class="flex flex-col gap-1 px-3">
        <!-- Contactos se cargarán aquí -->
        <div
          class="p-2 text-xs text-slate-500 text-center sidebar-content opacity-0 pointer-events-none max-w-0 overflow-hidden ml-0 transition-all duration-500"
        >
          Cargando...
        </div>
      </div>
    </div>

    <!-- Pie: Compartir, Ajustes, Cerrar Sesión -->
    <SidebarFooter />
  </div>
</aside>

<style>
  /* Hide scrollbar when sidebar is collapsed (w-20) */
  #sidebar.w-20 .scrollable-container {
    overflow-y: hidden !important;
    overflow-x: hidden !important;
  }

  /* Show scrollbar when sidebar is expanded (w-72) */
  #sidebar.w-72 .scrollable-container {
    overflow-y: auto !important;
    overflow-x: hidden !important;
  }
</style>

<!-- PORTAL FLOTANTE PARA MENUS CONTEXTUALES -->
<div
  id="sidebar-floating-menu"
  class="hidden fixed w-48 bg-[#1a1a1a] border border-white/10 rounded-xl shadow-[0_0_30px_rgba(0,0,0,0.5)] z-9999 overflow-hidden animate-fade-in backdrop-blur-xl"
>
  <div id="floating-menu-content" class="p-1 flex flex-col gap-0.5">
    <!-- Dynamic content -->
  </div>
</div>

<script>
  // @ts-nocheck
  import {
    authService,
    userService,
    notificationService,
  } from "../../services/api.js";

  // ── Sistema de niveles (colores y nombres por XP) ──
  function obtenerNivel(xp) {
    if (xp >= 10001)
      return {
        id: "doctorado",
        color: "#A8E638",
        nombre: "Doctorado",
        min: 10001,
        max: Infinity,
      };
    if (xp >= 5001)
      return {
        id: "master",
        color: "#DB2777",
        nombre: "Magíster",
        min: 5001,
        max: 10000,
      };
    if (xp >= 2001)
      return {
        id: "licenciado",
        color: "#7C3AED",
        nombre: "Licenciado",
        min: 2001,
        max: 5000,
      };
    if (xp >= 501)
      return {
        id: "bachiller",
        color: "#3B82F6",
        nombre: "Bachiller",
        min: 501,
        max: 2000,
      };
    return {
      id: "novato",
      color: "#6B7280",
      nombre: "Novato",
      min: 0,
      max: 500,
    };
  }

  // ── Transferencia rápida desde el menú contextual ──
  window.handleQuickTransfer = (cedula) => {
    const enDashboard = window.location.pathname.includes("/dashboard");
    if (enDashboard) {
      window.dispatchEvent(
        new CustomEvent("quick-transfer-selected", { detail: { cedula } }),
      );
      const menu = document.getElementById("sidebar-floating-menu");
      if (menu) {
        menu.classList.add("hidden");
        menu.dataset.activeId = "";
      }
    } else {
      window.location.href = `/dashboard?transferTo=${cedula}`;
    }
  };

  // ── Menú contextual flotante de contactos ──
  window.toggleSidebarContactMenu = (event, id) => {
    event.preventDefault();
    event.stopPropagation();

    const btn = event.currentTarget;
    const name = btn.dataset.name;
    const cedula = btn.dataset.cedula;
    const floatingMenu = document.getElementById("sidebar-floating-menu");
    const floatingContent = document.getElementById("floating-menu-content");

    if (!floatingMenu || !floatingContent) return;

    if (
      !floatingMenu.classList.contains("hidden") &&
      floatingMenu.dataset.activeId === id
    ) {
      floatingMenu.classList.add("hidden");
      floatingMenu.dataset.activeId = "";
      return;
    }

    floatingContent.innerHTML = `
        <div class="px-3 py-2 border-b border-white/5 mb-1">
            <p class="text-xs font-bold text-white">${name}</p>
            <p class="text-[11px] text-slate-500">${cedula}</p>
        </div>
        <button onclick="window.handleQuickTransfer('${cedula}')" class="w-full text-left px-3 py-2 text-xs font-medium text-white hover:bg-brand-lime hover:text-black rounded-lg transition-colors flex items-center gap-2">
            <span>⚡</span> Transferencia Rápida
        </button>
        <button onclick="window.location.href='/finance/history?cedula=${cedula}'" class="w-full text-left px-3 py-2 text-xs font-medium text-slate-400 hover:bg-white/5 hover:text-white rounded-lg transition-colors">
            Ver Historial
        </button>
      `;

    const rect = btn.getBoundingClientRect();

    let top = rect.top;
    const left = rect.right + 12;

    const menuHeight = 150;
    if (top + menuHeight > window.innerHeight) {
      top = window.innerHeight - menuHeight - 20;
    }

    floatingMenu.style.top = `${top}px`;
    floatingMenu.style.left = `${left}px`;

    floatingMenu.classList.remove("hidden");
    floatingMenu.dataset.activeId = id;
  };

  // Cerrar menú flotante al hacer clic fuera de él
  document.addEventListener("click", (e) => {
    const floatingMenu = document.getElementById("sidebar-floating-menu");
    if (floatingMenu && !floatingMenu.classList.contains("hidden")) {
      const target = e.target;
      if (
        !target.closest("#sidebar-floating-menu") &&
        !target.closest('button[onclick*="toggleSidebarContactMenu"]')
      ) {
        floatingMenu.classList.add("hidden");
        floatingMenu.dataset.activeId = "";
      }
    }
  });

  // ── Inicialización del sidebar: carga nombre, XP y contactos ──
  async function initSidebar() {
    const user = authService.getCurrentUser();

    // Nombre de usuario
    const nameEl = document.getElementById("sidebar-username");
    if (user && nameEl)
      nameEl.textContent = user.nombre || user.name || "Usuario";

    // XP actual (fallback a 1500 si no hay datos)
    const xp = user ? user.xp || user.puntos || 1500 : 1500;
    const nivel = obtenerNivel(xp);

    // Borde de la foto de perfil coloreado según nivel
    const fotoEl = document.getElementById("sidebar-profile-photo");
    if (fotoEl) {
      fotoEl.style.borderColor = nivel.color;
      fotoEl.style.boxShadow = `0 0 20px ${nivel.color}40`;
    }

    // Actualizar barra de progreso XP
    const levelTextEl = document.getElementById("sidebar-level-text");
    const levelXpEl = document.getElementById("sidebar-level-xp");
    const levelMaxEl = document.getElementById("sidebar-level-max");
    const levelBarEl = document.getElementById("sidebar-level-bar");

    if (levelTextEl) levelTextEl.textContent = `Nivel ${nivel.nombre}`;
    if (levelXpEl) levelXpEl.textContent = `${xp} XP`;
    if (levelMaxEl)
      levelMaxEl.textContent =
        nivel.id === "doctorado" ? "∞ XP" : `${nivel.max} XP`;

    if (levelBarEl) {
      const progreso =
        nivel.id === "doctorado"
          ? 100
          : ((xp - nivel.min) / (nivel.max - nivel.min)) * 100;
      levelBarEl.style.width = `${Math.min(100, Math.max(0, progreso))}%`;
      levelBarEl.style.backgroundColor = nivel.color;
      levelBarEl.style.boxShadow = `0 0 10px ${nivel.color}60`;
    }

    // Carga de contactos frecuentes
    const listEl = document.getElementById("sidebar-contacts-list");
    if (listEl && user) {
      try {
        const result = await userService.getContacts(user.id || user.usuarioId);
        const contactos = result.contactos || [];

        const addBtnHtml = `
            <a href="/account/contacts" class="group/add flex items-center p-2 rounded-lg hover:bg-white/5 transition-colors relative w-full text-left mt-1">
                <div class="relative shrink-0">
                    <div class="w-9 h-9 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 group-hover/add:text-brand-lime transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                    </div>
                </div>
                <div class="overflow-hidden whitespace-nowrap sidebar-content opacity-0 pointer-events-none max-w-0 ml-0 transition-all duration-500 ease-in-out">
                <p class="text-sm text-slate-200 group-hover/add:text-brand-lime font-medium truncate transition-colors">Ver todos / Añadir</p>
                </div>
            </a>`;

        if (!contactos || contactos.length === 0) {
          listEl.innerHTML = `<div class="p-2 text-xs text-slate-500 text-center sidebar-content opacity-0 pointer-events-none max-w-0 overflow-hidden ml-0 transition-all duration-500">No hay contactos frecuentes</div>${addBtnHtml}`;
        } else {
          contactos.sort((a, b) =>
            b.is_favorite === a.is_favorite ? 0 : b.is_favorite ? 1 : -1,
          );

          let html = "";
          contactos.slice(0, 5).forEach((c) => {
            const star = c.is_favorite
              ? '<span class="text-brand-lime text-[11px] ml-1">★</span>'
              : "";

            html += `
                    <div class="group/item relative">
                        <button 
                            class="w-full flex items-center p-2 rounded-lg hover:bg-white/5 transition-colors relative cursor-pointer text-left focus:outline-none"
                            onclick="window.toggleSidebarContactMenu(event, '${c.id}')"
                            data-name="${c.nombre}"
                            data-cedula="${c.cedula}"
                            title="${c.nombre}"
                        >
                            <div class="relative shrink-0">
                                <div class="w-9 h-9 rounded-full bg-slate-700 flex items-center justify-center text-xs font-bold text-slate-300 border border-white/5">
                                    ${c.iniciales}
                                </div>
                                <span class="absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full border-2 border-[#0a0a0a0a] bg-emerald-500"></span>
                            </div>
                            <div class="flex-1 overflow-hidden whitespace-nowrap sidebar-content opacity-0 pointer-events-none max-w-0 ml-0 transition-all duration-500 ease-in-out min-w-0">
                                <div class="flex justify-between items-center w-full">
                                    <div class="overflow-hidden min-w-0">
                                        <p class="text-sm text-slate-200 font-medium truncate flex items-center">
                                            ${c.nombre} ${star}
                                        </p>
                                        <p class="text-xs text-slate-500 truncate capitalize">Amigo</p>
                                    </div>
                                    <div class="text-slate-500 group-hover/item:text-brand-lime transition-colors">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" /></svg>
                                    </div>
                                </div>
                            </div>
                        </button>
                    </div>`;
          });
          listEl.innerHTML = html + addBtnHtml;

          if (!isCollapsed) {
            document
              .querySelectorAll("#sidebar-contacts-list .sidebar-content")
              .forEach((el) => {
                el.classList.remove(
                  "opacity-0",
                  "pointer-events-none",
                  "max-w-0",
                  "ml-0",
                );
                el.classList.add("max-w-xs", "ml-3");
              });
          }
        }
      } catch (e) {
        console.error("Error cargando contactos del sidebar:", e);
      }
    }
  }

  initSidebar();

  // ── Referencias a elementos del DOM ──
  const sidebar = document.getElementById("sidebar");
  const toggleBtn = document.getElementById("sidebarToggle");
  const toggleIcon = document.getElementById("toggleIcon");
  const searchTrigger = document.getElementById("sidebar-search-trigger");

  // ── Cerrar sesión ──
  const logoutBtn = document.getElementById("desktop-logout-btn");
  if (logoutBtn) {
    logoutBtn.addEventListener("click", (e) => {
      e.preventDefault();
      if (window.showLogoutModal) {
        window.showLogoutModal();
      } else {
        authService.logout();
      }
    });
  }

  // ── Sistema de notificaciones: polling + badges ──
  // Persistir IDs de notificaciones ya mostradas para no repetir toasts
  const CLAVE_NOTIFS = "capypay_shown_notifs";

  function obtenerIdsVistos() {
    try {
      const stored = localStorage.getItem(CLAVE_NOTIFS);
      // Convertir siempre a String para evitar mismatch número/string de Supabase
      return stored ? new Set(JSON.parse(stored).map(String)) : new Set();
    } catch {
      return new Set();
    }
  }

  function guardarIdVisto(id) {
    try {
      const vistos = obtenerIdsVistos();
      vistos.add(String(id));
      // Límite de 100 IDs para no saturar localStorage
      const arr = Array.from(vistos).slice(-100);
      localStorage.setItem(CLAVE_NOTIFS, JSON.stringify(arr));
    } catch (e) {
      console.error("Error guardando ID de notificación:", e);
    }
  }

  // Actualiza los badges de notificación en sidebar y campana del dashboard
  function actualizarBadgeNotif(cantidad) {
    const badgeIcono = document.getElementById("sidebar-notif-badge"); // sidebar colapsado
    const badgeTexto = document.getElementById("sidebar-notif-badge-text"); // sidebar expandido
    const badgeMovil = document.getElementById("mobile-notif-badge"); // campana móvil
    const badges = [badgeIcono, badgeTexto, badgeMovil];
    const etiqueta = cantidad > 99 ? "99+" : String(cantidad);

    if (cantidad > 0) {
      badges.forEach((b) => {
        if (!b) return;
        b.textContent = etiqueta;
        b.classList.remove("hidden");
        b.style.display = "flex";
      });
    } else {
      badges.forEach((b) => {
        if (!b) return;
        b.style.display = "";
        b.classList.add("hidden");
      });
    }
  }

  // Los toasts solo aparecen en el dashboard (no en cada página)
  const estamosEnDashboard = window.location.pathname === "/dashboard";

  // Polling de notificaciones cada 10 segundos
  async function verificarNotificaciones() {
    const user = authService.getCurrentUser();
    const userId = user?.id || user?.usuarioId || user?._id;
    if (!userId) return;

    try {
      const { notifications } =
        await notificationService.getNotifications(userId);

      if (notifications && notifications.length > 0) {
        const idsVistos = obtenerIdsVistos();
        const noLeidas = notifications.filter((n) => !n.is_read).length;
        actualizarBadgeNotif(noLeidas);

        // Mostrar toasts solo en el dashboard y solo para notificaciones nuevas
        if (estamosEnDashboard) {
          notifications.forEach((n) => {
            if (!n.is_read && !idsVistos.has(String(n.id))) {
              const tipo = n.type === "payment_received" ? "success" : "info";
              const titulo =
                n.type === "payment_received"
                  ? "Pago Recibido"
                  : "Nueva Notificación";
              window.showToast(n.message, tipo, titulo);
              guardarIdVisto(n.id);
            }
          });
        }
      } else {
        actualizarBadgeNotif(0);
      }
    } catch (e) {
      console.error("Error en polling de notificaciones:", e);
    }
  }

  // Primera verificación tras 1.5s de carga; luego cada 10s
  setTimeout(verificarNotificaciones, 1500);
  setInterval(verificarNotificaciones, 10000);

  const toggleContainer = document.getElementById("toggleContainer");
  let isCollapsed = true;
  let toggleTimeout;

  function expandSidebar() {
    isCollapsed = false;
    if (toggleTimeout) clearTimeout(toggleTimeout);

    const contenidos = document.querySelectorAll(".sidebar-content");
    const perfil = document.querySelector(".profile-content");
    const searchInput = document.getElementById("sidebar-search-input");
    const foto = document.getElementById("sidebar-profile-photo");

    sidebar?.classList.remove("w-20");
    sidebar?.classList.add("w-72");
    toggleContainer?.classList.add("justify-end", "px-4");
    toggleContainer?.classList.remove("justify-center", "px-0");

    // Agrandar foto de perfil
    if (foto) {
      foto.classList.replace("w-9", "w-16");
      foto.classList.replace("h-9", "h-16");
    }

    // Mostrar info de perfil
    if (perfil) {
      perfil.classList.remove("max-h-0", "opacity-0");
      perfil.classList.add("max-h-40", "opacity-100");
    }

    // Mostrar buscador
    searchInput?.classList.add(
      "w-full",
      "pl-10",
      "pr-3",
      "py-2",
      "border",
      "opacity-100",
    );
    searchInput?.classList.remove(
      "w-0",
      "p-0",
      "border-0",
      "opacity-0",
      "pointer-events-none",
    );

    // Mostrar etiquetas de texto
    contenidos.forEach((el) => {
      el.classList.remove(
        "opacity-0",
        "pointer-events-none",
        "max-w-0",
        "ml-0",
      );
      el.classList.add("max-w-xs", "ml-3");
    });

    toggleIcon?.classList.remove("rotate-180");
  }

  function collapseSidebar() {
    isCollapsed = true;
    if (toggleTimeout) clearTimeout(toggleTimeout);

    const contenidos = document.querySelectorAll(".sidebar-content");
    const perfil = document.querySelector(".profile-content");
    const searchInput = document.getElementById("sidebar-search-input");
    const foto = document.getElementById("sidebar-profile-photo");

    sidebar?.classList.remove("w-72");
    sidebar?.classList.add("w-20");
    toggleContainer?.classList.remove("justify-end", "px-4");
    toggleContainer?.classList.add("justify-center", "px-0");

    // Reducir foto de perfil
    if (foto) {
      foto.classList.replace("w-16", "w-9");
      foto.classList.replace("h-16", "h-9");
    }

    // Ocultar info de perfil
    if (perfil) {
      perfil.classList.remove("max-h-40", "opacity-100");
      perfil.classList.add("max-h-0", "opacity-0");
    }

    // Ocultar buscador
    searchInput?.classList.remove(
      "w-full",
      "pl-10",
      "pr-3",
      "py-2",
      "border",
      "opacity-100",
    );
    searchInput?.classList.add(
      "w-0",
      "p-0",
      "border-0",
      "opacity-0",
      "pointer-events-none",
    );

    // Ocultar etiquetas de texto
    contenidos.forEach((el) => {
      el.classList.add("opacity-0", "pointer-events-none", "max-w-0", "ml-0");
      el.classList.remove("max-w-xs", "ml-3");
    });

    toggleIcon?.classList.add("rotate-180");
  }

  toggleBtn?.addEventListener("click", () => {
    if (isCollapsed) expandSidebar();
    else collapseSidebar();
  });

  // Expandir al hacer clic en el buscador cuando está colapsado
  searchTrigger?.addEventListener("click", () => {
    if (isCollapsed) {
      expandSidebar();
      setTimeout(
        () => document.getElementById("sidebar-search-input")?.focus(),
        300,
      );
    }
  });
</script>
