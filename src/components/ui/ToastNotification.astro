<div
  id="toast-container"
  class="fixed top-4 right-4 z-99999 flex flex-col gap-4 pointer-events-none"
>
  <!-- Toasts injected here -->
</div>

<template id="toast-template">
  <div
    class="pointer-events-auto min-w-[300px] max-w-sm bg-white border-[4px] border-black p-4 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] flex items-start gap-3 transform transition-all duration-300 translate-x-10 opacity-0 relative overflow-hidden group mb-2"
  >
    <!-- Accent Color Bar -->
    <div
      class="absolute left-0 top-0 bottom-0 w-3 toast-color-bar border-r-[4px] border-black"
    >
    </div>

    <!-- Icon -->
    <div class="shrink-0 pt-0.5 ml-3">
      <div class="w-6 h-6 flex items-center justify-center icon-container">
        <!-- Icon SVG -->
      </div>
    </div>
    <!-- Content -->
    <div class="flex-1">
      <h4
        class="text-base font-black text-black uppercase tracking-tight title leading-tight"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Notificación
      </h4>
      <p
        class="text-sm font-bold text-black/60 mt-1 uppercase tracking-tight message leading-tight"
        style="font-family: 'Space Grotesk', sans-serif;"
      >
        Mensaje aquí
      </p>
    </div>
    <!-- Close -->
    <button
      class="text-black font-black hover:scale-110 active:scale-90 transition-transform shrink-0 close-btn -mt-1 -mr-1 p-1"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="3"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</template>

<script>
  // @ts-nocheck
  // Icons
  const icons = {
    success: {
      barClass: "bg-[#d7fd48]",
      text: "text-[#d7fd48]",
      bg: "bg-black shadow-[2px_2px_0px_0px_rgba(215,253,72,1)] border-2 border-black",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7" /></svg>`,
    },
    error: {
      barClass: "bg-[#DB2777]",
      text: "text-[#DB2777]",
      bg: "bg-black shadow-[2px_2px_0px_0px_rgba(219,39,119,1)] border-2 border-black",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M6 18L18 6M6 6l12 12" /></svg>`,
    },
    info: {
      barClass: "bg-[#8CFFE1]",
      text: "text-[#8CFFE1]",
      bg: "bg-black shadow-[2px_2px_0px_0px_rgba(140,255,225,1)] border-2 border-black",
      svg: `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    },
  };

  // Define showToast on global scope
  window.showToast = (message, type = "info", title = "") => {
    const container = document.getElementById("toast-container");
    const template = document.getElementById("toast-template");

    if (!container || !template) return;

    // Default Titles
    if (!title) {
      if (type === "success") title = "¡Éxito!";
      if (type === "error") title = "Error";
      if (type === "info") title = "Información";
    }

    // Clone
    const clone = template.content.cloneNode(true);
    const toast = clone.querySelector("div");

    if (!toast) return;

    // Setup Content
    const titleEl = toast.querySelector(".title");
    const msgEl = toast.querySelector(".message");
    if (titleEl) titleEl.innerText = title;
    if (msgEl) msgEl.innerText = message;

    // Setup Icon
    const iconConfig = icons[type] || icons.info;
    const iconContainer = toast.querySelector(".icon-container");
    if (iconContainer) {
      iconContainer.innerHTML = iconConfig.svg;
      iconContainer.className = `w-7 h-7 flex items-center justify-center shrink-0 ${iconConfig.bg} ${iconConfig.text}`;
    }

    // Setup color bar
    const colorBar = toast.querySelector(".toast-color-bar");
    if (colorBar) {
      colorBar.className = `absolute left-0 top-0 bottom-0 w-3 border-r-[4px] border-black ${iconConfig.barClass}`;
    }

    // Append
    container.appendChild(toast);

    // Animate In (neobrutalist quick slide)
    requestAnimationFrame(() => {
      toast.classList.remove("translate-x-10", "opacity-0");
    });

    // Auto Remove
    const timeout = setTimeout(() => {
      removeToast(toast);
    }, 4000);

    // Manual Close
    const closeBtn = toast.querySelector(".close-btn");
    if (closeBtn) {
      closeBtn.addEventListener("click", () => {
        clearTimeout(timeout);
        removeToast(toast);
      });
    }
  };

  function removeToast(el) {
    el.classList.add("translate-x-10", "opacity-0");
    setTimeout(() => {
      el.remove();
    }, 300);
  }

  // Event Listener wrapper for easy dispatching from other components
  window.addEventListener("toast", (e) => {
    const customEvent = e;
    if (customEvent.detail) {
      const { message, type, title } = customEvent.detail;
      window.showToast(message, type, title);
    }
  });
</script>
