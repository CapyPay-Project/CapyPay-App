---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  href?: string;
  variant?: "primary" | "secondary" | "ghost" | "icon";
  size?: "sm" | "md" | "lg" | "icon";
  class?: string;
  disabled?: boolean;
  type?: "button" | "submit" | "reset";
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  disabled = false,
  type = "button",
  ...rest
} = Astro.props;

const Element = href ? "a" : "button";

const baseStyles =
  "inline-flex items-center justify-center font-black uppercase tracking-widest transition-all active:translate-y-0 disabled:opacity-50 disabled:pointer-events-none cursor-pointer border-4 border-black hover:-translate-y-1 hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]";

const variants: Record<string, string> = {
  primary: "bg-[#d7fd48] text-black",
  secondary: "bg-white text-black",
  ghost: "bg-transparent border-transparent text-black hover:bg-black hover:text-white",
  icon: "bg-white text-black flex items-center justify-center aspect-square",
};

const sizes: Record<string, string> = {
  sm: "text-xs py-2 px-4 gap-2",
  md: "text-sm sm:text-base py-3 px-6 gap-3",
  lg: "text-base sm:text-lg py-4 px-8 gap-4",
  icon: "p-2 min-w-10 min-h-10",
};

const sizeClasses = variant === "icon" ? sizes.icon : sizes[size];
const variantClasses = variants[variant] || variants.primary;

const finalClass = `${baseStyles} ${variantClasses} ${sizeClasses} ${className}`;
---

<Element
  href={href}
  type={!href ? type : undefined}
  class={finalClass}
  disabled={disabled}
  {...rest}
>
  <slot />
</Element>

