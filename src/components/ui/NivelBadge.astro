---
const {
  nombre = "Bachiller",
  xp = 1500,
  icono = "🎓",
  id = undefined,
  extraClass = "",
  showDetails = false,
} = Astro.props;
---

<a
  href="/account/niveles"
  id={id}
  class={`nivel-badge bg-black/80 backdrop-blur-md -full px-2 sm:px-3 py-1 border-4 border-black flex items-center gap-1.5 sm:gap-2 hover:border-brand-lime/50 transition-all group ${extraClass}`}
  aria-label={`Ver niveles — ${nombre} — ${xp} XP`}
  title={`Ver niveles — ${nombre} — ${xp} XP`}
>
  {
    showDetails ? (
      <span class="nivel-text text-brand-lime font-bold text-sm group-hover:scale-105 transition-transform">
        {icono} {nombre}
      </span>
    ) : (
      <span class="text-brand-lime font-bold text-sm group-hover:scale-105 transition-transform">
        Nivel
      </span>
    )
  }
  <svg
    class="w-3 h-3 text-black font-semibold group-hover:text-brand-lime transition-colors"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M9 5l7 7-7 7"></path>
  </svg>
</a>
