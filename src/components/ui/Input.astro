---
const {
  type = "text",
  placeholder = "",
  name,
  id,
  value,
  required = false,
  disabled = false,
  label,
  class: className = "",
  ...rest
} = Astro.props;

const hasIcon = Astro.slots.has("icon");
---

<div class={`w-full ${className}`}>
  {
    label && (
      <label
        for={id}
        class="block text-sm font-black text-black mb-1.5 ml-1 uppercase"
      >
        {label}
      </label>
    )
  }
  <div class="relative">
    {
      hasIcon && (
        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-black pointer-events-none">
          <slot name="icon" />
        </div>
      )
    }
    <input
      type={type}
      name={name}
      id={id}
      value={value}
      placeholder={placeholder}
      required={required}
      disabled={disabled}
      class={`w-full bg-[#f4f4f5] border-4 border-black text-black placeholder-gray-500 font-bold py-3 px-4 focus:outline-none focus:bg-[#d7fd48] transition-colors ${
        hasIcon ? "pl-10" : ""
      }`}
      {...rest}
    />
  </div>
</div>

