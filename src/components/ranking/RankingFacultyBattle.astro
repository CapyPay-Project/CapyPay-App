---
// RankingFacultyBattle.astro
// Barra de batalla entre las dos facultades con más XP.
// Contenido poblado por rankingLogic.js → actualizarBatallaFacultades()
---

<div
  id="faculty-battle-summary"
  class="bg-white border-2 border-black border-4 border-black -xl p-4 transition-all duration-300"
>
  <div class="flex justify-between items-end mb-2">
    <span class="text-xs font-bold uppercase tracking-wider text-white/60"
      >Batalla de Facultades</span
    >
    <span
      id="battle-details-text"
      class="text-xs text-brand-lime font-black italic">Cargando datos...</span
    >
  </div>
  <div
    id="battle-bar-container"
    class="relative h-4 w-full bg-white border-2 border-black -full overflow-hidden flex"
  >
    <!-- Placeholder animado mientras carga -->
    <div class="h-full bg-white/20 w-1/2 animate-pulse"></div>
    <div class="h-full bg-white border-2 border-black w-1/2 animate-pulse"></div>
  </div>
</div>
