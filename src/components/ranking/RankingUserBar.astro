---
// RankingUserBar.astro
// Barra inferior del usuario autenticado: posición, progreso hacia su rival y puntos totales.
// Poblado por rankingLogic.js → actualizarFooter()
---

<div
  class="bg-[#0a0b08]/90 border border-brand-lime/30 -2xl py-4 px-6 md:px-12 shadow-[0_10px_30px_rgba(0,0,0,0.5)]"
>
  <div class="flex flex-col md:flex-row items-center justify-between gap-4">
    <!-- Info del usuario -->
    <div
      class="flex items-center gap-4 w-full md:w-auto justify-between md:justify-start"
    >
      <div class="flex items-center gap-4">
        <div
          class="size-12 -full border-2 border-brand-lime p-0.5 overflow-hidden glow-lime"
        >
          <img
            id="user-avatar-footer"
            class="w-full h-full -full object-cover"
            src="https://ui-avatars.com/api/?background=random&color=fff&name=Me"
            alt="User"
          />
        </div>
        <div>
          <p class="text-sm text-white/60 font-medium">Tu posición actual</p>
          <p class="text-2xl font-black text-white italic">
            RANK <span id="user-rank" class="text-brand-lime"># -</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Barra de progreso vs rival -->
    <div class="flex-1 max-w-2xl w-full flex flex-col gap-1.5 px-1">
      <div
        class="flex justify-between items-end text-xs font-black uppercase italic tracking-wider"
      >
        <span class="text-white/70">Nivel Actual</span>
        <div class="flex items-center gap-2">
          <span id="rival-text" class="text-brand-lime text-right"
            >Cargando rival...</span
          >
          <div
            class="size-6 -full border border-white/20 overflow-hidden"
            title="Rival Directo"
          >
            <img
              id="rival-avatar-footer"
              src="https://ui-avatars.com/api/?background=random&color=fff&name=Rival"
              class="w-full h-full object-cover"
              alt="Rival"
            />
          </div>
        </div>
      </div>
      <div
        class="h-3 w-full bg-white border-2 border-black -full overflow-hidden border-4 border-black"
      >
        <div
          id="rival-progress-bar"
          class="h-full bg-linear-to-r from-brand-lime/60 to-brand-lime w-[0%] -full relative transition-all duration-1000"
        >
          <div class="absolute inset-0 bg-white/20 animate-pulse"></div>
        </div>
      </div>
    </div>

    <!-- Puntos + botón compartir (solo desktop) -->
    <div class="items-center gap-3 hidden md:flex">
      <div class="text-right">
        <p class="text-xs text-white/70 font-bold">Total Puntos</p>
        <p
          id="user-points-footer"
          class="text-lg font-black text-brand-lime italic"
        >
          0
        </p>
      </div>
      <button
        class="bg-white border-2 border-black hover:bg-white border-2 border-black p-3 -xl border-4 border-black transition-colors cursor-pointer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          height="24px"
          viewBox="0 -960 960 960"
          width="24px"
          fill="white"
        >
          <path
            d="M720-80q-50 0-85-35t-35-85q0-7 1-14.5t3-13.5L322-392q-17 15-38 23.5t-44 8.5q-50 0-85-35t-35-85q0-50 35-85t85-35q23 0 44 8.5t38 23.5l282-164q-2-6-3-13.5t-1-14.5q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35q-23 0-44-8.5T638-672L356-508q2 6 3 13.5t1 14.5q0 7-1 14.5t-3 13.5l282 164q17-15 38-23.5t44-8.5q50 0 85 35t35 85q0 50-35 85t-85 35Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</div>
