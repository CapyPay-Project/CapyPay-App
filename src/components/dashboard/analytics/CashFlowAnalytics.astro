---
// Neo-brutalist FinanceChart
---

<div
  class="h-full w-full bg-white border-4 border-black box-shadow-brutal p-4 sm:p-5 flex flex-col justify-between"
  id="finance-chart-widget"
>
  <div
    class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 gap-2"
  >
    <div>
      <h3
        class="font-black text-lg sm:text-xl uppercase tracking-tighter text-black leading-none"
        id="flujo-title"
      >
        ANALÍTICAS DE FLUJO
      </h3>
      <div class="flex gap-4 mt-1 text-xs font-bold font-mono uppercase">
        <span class="text-green-600"
          ><span id="total-ingresos">Bs. +0.00</span></span
        >
        <span class="text-red-500"
          ><span id="total-egresos">Bs. -0.00</span></span
        >
      </div>
    </div>
    <div class="flex gap-2 items-center flex-wrap">
      <select
        id="chart-filter"
        class="border-2 border-black font-black uppercase text-xs p-1 focus:outline-none bg-white cursor-pointer hover:bg-gray-100"
      >
        <option value="weekly">Semanal</option>
        <option value="monthly">Mensual</option>
        <option value="trimestral">Trimestral</option>
      </select>
    </div>
  </div>

  <div
    class="grow flex items-end justify-between pt-6 border-b-4 border-black relative"
    id="chart-bars-container"
  >
    <!-- Bars generated by JS -->
  </div>

  <div
    class="flex justify-between mt-4 px-2 text-[10px] sm:text-xs font-black uppercase text-black"
    id="chart-labels-container"
  >
    <!-- Labels generated by JS -->
  </div>
</div>

<style>
  .box-shadow-brutal {
    box-shadow: 4px 4px 0px 0px rgba(0, 0, 0, 1);
  }
</style>

<script>
  import { userService } from "../../../services/api.js";

  async function loadFinanceData() {
    const barsContainer = document.getElementById("chart-bars-container");
    const labelsContainer = document.getElementById("chart-labels-container");
    const chartFilter = document.getElementById(
      "chart-filter",
    ) as HTMLSelectElement | null;
    const totalIngresos = document.getElementById("total-ingresos");
    const totalEgresos = document.getElementById("total-egresos");
    const btnExpenses = document.getElementById("btn-show-expenses");
    const btnIncome = document.getElementById("btn-show-income");
    const flujoTitle = document.getElementById("flujo-title");
    if (!barsContainer || !labelsContainer) return;

    let currentView = "expenses";
    let history: any[] = [];
    let updateChart = () => {};

    if (btnExpenses && btnIncome) {
      btnExpenses.onclick = () => {
        currentView = "expenses";
        btnExpenses.classList.replace("bg-white", "bg-black");
        btnExpenses.classList.replace("text-black", "text-white");
        btnIncome.classList.replace("bg-black", "bg-white");
        btnIncome.classList.replace("text-white", "text-black");
        if (flujoTitle) flujoTitle.innerText = "FLUJO DE EGRESOS";
        updateChart();
      };
      btnIncome.onclick = () => {
        currentView = "income";
        btnIncome.classList.replace("bg-white", "bg-black");
        btnIncome.classList.replace("text-black", "text-white");
        btnExpenses.classList.replace("bg-black", "bg-white");
        btnExpenses.classList.replace("text-white", "text-black");
        if (flujoTitle) flujoTitle.innerText = "FLUJO DE INGRESOS";
        updateChart();
      };
    }

    try {
      const profile = await userService.getProfile();
      if (profile && profile.cedula) {
        const rawHistory: any = await userService
          .getHistory(profile.cedula)
          .catch(() => ({ movimientos: [] }));
        history = Array.isArray(rawHistory)
          ? rawHistory
          : rawHistory.movimientos || rawHistory.data || [];
      }

      updateChart = () => {
        const filterVal = chartFilter ? chartFilter.value : "weekly";
        let daysToCalculate = 5;
        let periodLabel = "day";

        if (filterVal === "monthly") {
          daysToCalculate = 30;
          periodLabel = "week";
        } else if (filterVal === "trimestral") {
          daysToCalculate = 90;
          periodLabel = "month";
        }

        const now = new Date();
        const cutoffDate = new Date();
        cutoffDate.setDate(now.getDate() - daysToCalculate);

        let ingresos = 0;
        let egresos = 0;

        const filteredHistory = history.filter(
          (h: any) => new Date(h.fecha) >= cutoffDate,
        );
        filteredHistory.forEach((h: any) => {
          const val = parseFloat(h.monto || 0);
          if (h.es_negativo || val < 0 || h.tipo === "retiro") {
            egresos += Math.abs(val);
          } else {
            ingresos += Math.abs(val);
          }
        });

        if (totalIngresos)
          totalIngresos.innerText = `Bs. +${ingresos.toFixed(2)}`;
        if (totalEgresos) totalEgresos.innerText = `Bs. -${egresos.toFixed(2)}`;

        const dataToRender = filteredHistory.filter((h: any) => {
          const isExpense =
            h.es_negativo ||
            parseFloat(h.monto || 0) < 0 ||
            h.tipo === "retiro";
          return currentView === "expenses" ? isExpense : !isExpense;
        });

        let dataPoints: any[] = [];
        if (filterVal === "weekly") {
          for (let i = 4; i >= 0; i--) {
            const d = new Date();
            d.setDate(d.getDate() - i);
            dataPoints.push({
              dateStr: d.toISOString().split("T")[0],
              label: d.toLocaleDateString("es-ES", { weekday: "short" }),
              val: 0,
            });
          }
          dataToRender.forEach((ex: any) => {
            const date = new Date(ex.fecha).toISOString().split("T")[0];
            const dp = dataPoints.find((d: any) => d.dateStr === date);
            if (dp) dp.val += Math.abs(parseFloat(ex.monto));
          });
        } else {
          const chunksCount = filterVal === "monthly" ? 4 : 3;
          for (let i = chunksCount - 1; i >= 0; i--) {
            dataPoints.push({
              label: filterVal === "monthly" ? `Sem ${4 - i}` : `Mes ${3 - i}`,
              val: 0,
              index: i,
            });
          }
          dataToRender.forEach((ex: any) => {
            const diffTime = Math.abs(
              now.getTime() - new Date(ex.fecha).getTime(),
            );
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            let targetIdx = 0;
            if (filterVal === "monthly") {
              targetIdx = Math.floor(diffDays / 7.5);
              targetIdx = Math.min(targetIdx, 3);
            } else {
              targetIdx = Math.floor(diffDays / 30);
              targetIdx = Math.min(targetIdx, 2);
            }
            const targetDp = dataPoints.find(
              (dp: any) => dp.index === targetIdx,
            );
            if (targetDp) {
              targetDp.val += Math.abs(parseFloat(ex.monto));
            }
          });
          dataPoints.reverse();
        }

        const maxVal = Math.max(...dataPoints.map((d: any) => d.val), 10);

        barsContainer.innerHTML = dataPoints
          .map((d: any, i: number) => {
            const heightPercent = (d.val / maxVal) * 100;
            const color = i % 2 === 0 ? "bg-[#8b5cf6]" : "bg-[#d7fd48]";
            return `<div class="flex flex-col justify-end items-center flex-1 h-full relative group">
            <div class="w-full max-w-[40px] ${color} border-4 border-black relative transition-all duration-500 ease-out hover:-translate-y-1" style="height: ${heightPercent}%">
               <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-black text-white text-xs font-black px-2 py-1 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">Bs.${d.val.toFixed(2)}</div>
            </div>
          </div>`;
          })
          .join("");

        labelsContainer.innerHTML = dataPoints
          .map((d: any) => {
            return `<div class="flex-1 text-center truncate">${d.label}</div>`;
          })
          .join("");
      };

      if (chartFilter) {
        chartFilter.addEventListener("change", updateChart);
      }

      updateChart();
    } catch (e) {
      console.error("Error loading finance data", e);
      barsContainer.innerHTML =
        '<p class="w-full text-center font-bold absolute top-1/2">Error cargando gastos</p>';
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadFinanceData);
  } else {
    loadFinanceData();
  }
</script>
