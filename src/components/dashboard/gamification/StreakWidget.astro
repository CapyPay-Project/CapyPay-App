---
---

<div
  class="bg-white border-4 border-black box-shadow-brutal p-4 sm:p-5 flex flex-col justify-between h-32 sm:h-full"
  aria-label="Estado de racha"
>
  <div class="flex items-start justify-between">
    <span class="material-symbols-outlined text-3xl text-black">local_fire_department</span>
    <span class="bg-[#d7fd48] border-2 border-black px-2 py-0.5 text-[10px] font-black uppercase">Racha</span>
  </div>

  <div class="mt-2">
    <div class="flex items-end justify-between gap-3">
      <p class="text-black text-xs font-black uppercase">Diaria</p>
      <p id="streak-daily" class="text-black text-2xl font-black leading-none">0</p>
    </div>
    <div class="flex items-center justify-between mt-1">
      <p id="streak-weekly" class="text-[10px] font-black uppercase text-gray-700">Semanal: 0</p>
      <p id="streak-shield" class="text-[10px] font-black uppercase text-black bg-white border-2 border-black px-2 py-0.5">Escudo: 1</p>
    </div>
    <p id="streak-warning" class="hidden mt-1 text-[10px] font-black uppercase text-[#b91c1c]">
      En riesgo: activa hoy tu racha
    </p>
  </div>
</div>
