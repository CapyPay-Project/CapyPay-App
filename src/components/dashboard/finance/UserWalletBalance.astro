---
const { amount = "0.00" } = Astro.props;
---

<div
  class="relative overflow-hidden p-6 sm:p-8 bg-[#d7fd48] border-4 border-black box-shadow-brutal w-full -2xl transition-transform hover:-translate-y-1"
>
  <!-- Paw Print Background (Decorative) -->
  <div
    class="absolute -right-4 -top-10 opacity-10 pointer-events-none scale-150 transform rotate-12"
  >
    <svg
      width="200"
      height="200"
      viewBox="0 0 24 24"
      fill="currentColor"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M12 2C9.243 2 7 4.243 7 7C7 9.757 9.243 12 12 12C14.757 12 17 9.757 17 7C17 4.243 14.757 2 12 2ZM6.5 13C4.567 13 3 14.567 3 16.5C3 18.433 4.567 20 6.5 20C8.433 20 10 18.433 10 16.5C10 14.567 8.433 13 6.5 13ZM17.5 13C15.567 13 14 14.567 14 16.5C14 18.433 15.567 20 17.5 20C19.433 20 21 18.433 21 16.5C21 14.567 19.433 13 17.5 13ZM12 13.5C9.5 13.5 8 15 8 17.5C8 19.985 10.015 22 12 22C13.985 22 16 19.985 16 17.5C16 15 14.5 13.5 12 13.5Z"
      ></path>
    </svg>
  </div>

  <div class="relative z-10 flex flex-col justify-between h-full min-h-[160px]">
    <!-- Top Row -->
    <div class="flex justify-between items-start">
      <div
        class="bg-black text-[#d7fd48] px-3 py-1 font-black text-[10px] uppercase tracking-widest border-2 border-black"
      >
        ACTIVOS FIJOS
      </div>
      <!-- Logo circle/card thing -->
      <div class="flex">
        <div
          class="w-8 h-8 -full border-2 border-black mix-blend-multiply opacity-60"
        >
        </div>
        <div
          class="w-8 h-8 -full border-2 border-black -ml-4 mix-blend-multiply opacity-60 bg-[#8b5cf6]"
        >
        </div>
      </div>
    </div>

    <!-- Center Balance -->
    <div class="mt-4 mb-6">
      <span class="text-xl sm:text-2xl font-black text-black mr-1">$</span>
      <span
        id="balance-amount"
        class="text-5xl sm:text-6xl lg:text-7xl font-black text-black tracking-tighter mix-blend-normal"
      >
        {amount}
      </span>
    </div>

    <!-- Bottom Row -->
    <div class="flex justify-between items-end">
      <div>
        <p
          class="text-[10px] font-black uppercase text-black/70 tracking-widest"
        >
          TITULAR
        </p>
        <p
          id="balance-username"
          class="text-sm sm:text-base font-black text-black uppercase tracking-widest mt-0.5"
        >
          MAXIMUS CAPYBARA
        </p>
      </div>
      <div class="text-base sm:text-lg font-black text-black tracking-widest">
        **** 9021
      </div>
    </div>
  </div>
</div>

<style>
  .box-shadow-brutal {
    box-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
  }
</style>

<script>
  import { authService, userService } from "../../../services/api.js";

  async function updateBalance() {
    try {
      const user = authService.getCurrentUser();
      const nameEl = document.getElementById("balance-username");
      if (user && nameEl) {
        nameEl.innerText = (
          user.nombre ||
          user.name ||
          "Cormex User"
        ).toUpperCase();
      }

      if (!user) return;

      const profile = await userService.getProfile();
      const amountEl = document.getElementById("balance-amount");
      if (amountEl && profile) {
        amountEl.innerText = parseFloat(profile.balance).toLocaleString(
          "en-US",
          {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
          },
        );
      }
    } catch (e) {
      console.error("Error updating balance", e);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", updateBalance);
  } else {
    updateBalance();
  }
</script>
