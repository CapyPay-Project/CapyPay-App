<div
  id="transaction-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"
>
  <div
    class="bg-white border-[4px] border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] w-full max-w-md p-6 m-4 transform scale-95 transition-transform duration-300 relative overflow-hidden"
    style="font-family: 'Space Grotesk', sans-serif;"
  >
    <div class="flex justify-between items-start mb-6 border-b-[4px] border-black pb-4">
      <div>
        <h3 class="text-2xl font-black text-black uppercase tracking-tighter">TRANSACCIÓN</h3>
        <p class="text-black/70 text-xs mt-1 font-bold tracking-widest" id="modal-id">ID: #---</p>
      </div>
      <button
        id="close-modal-btn"
        class="p-2 bg-[#d7fd48] border-[3px] border-black text-black hover:-translate-y-1 hover:shadow-none shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="space-y-6">
      <div class="text-center py-6 bg-[#8CFFE1] border-[4px] border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transform -rotate-1">
        <p class="text-black text-xs font-black uppercase tracking-widest mb-1">
          Monto Total
        </p>
        <h2 class="text-4xl font-black text-black flex justify-center items-center gap-2" id="modal-amount">
          $0.00
        </h2>
        <span class="inline-block mt-2 px-3 py-1 text-[11px] font-black uppercase tracking-widest border-[2px] border-black bg-white text-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]" id="modal-status-badge">
          Completado
        </span>
      </div>

      <div class="grid grid-cols-2 gap-4 mt-8">
        <div class="bg-gray-100 border-[3px] border-black p-3 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] relative">
          <p class="text-black font-black text-[10px] uppercase tracking-widest opacity-60 absolute top-2 right-2">Fee</p>
          <p class="text-black font-black text-xs uppercase mb-1">Fecha</p>
          <p class="text-black text-sm font-bold mt-1" id="modal-date">--/--/----</p>
        </div>
        <div class="bg-gray-100 border-[3px] border-black p-3 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] relative">
          <p class="text-black font-black text-xs uppercase mb-1">Hora</p>
          <p class="text-black text-sm font-bold mt-1" id="modal-time">--:--</p>
        </div>
        <div class="col-span-2 bg-[#d7fd48] border-[3px] border-black p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transform rotate-1">
          <p class="text-black font-black text-[10px] uppercase tracking-widest mb-2 border-b-[2px] border-black pb-1">Concepto / Descripción</p>
          <p class="text-black text-base font-bold wrap-break-word leading-tight" id="modal-desc">---</p>
        </div>
        <div class="col-span-2 bg-white border-[3px] border-black p-3 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">
          <p class="text-black font-black text-[10px] uppercase tracking-widest mb-1">Tipo</p>
          <p class="text-[#8b5cf6] text-sm font-black uppercase tracking-wider" id="modal-type">---</p>
        </div>
      </div>
    </div>

    <div class="mt-8 flex justify-center">
      <button
        id="download-receipt-btn"
        class="w-full bg-black text-white hover:bg-[#8b5cf6] border-[3px] border-black py-4 font-black uppercase tracking-widest text-sm flex items-center justify-center gap-2 transition-colors group shadow-[4px_4px_0px_0px_rgba(139,92,246,1)] hover:-translate-y-1 hover:shadow-none"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        Descargar Comprobante
      </button>
    </div>
  </div>
</div>