---
import { Card } from "../../ui";
---

<Card
  class="p-6! relative overflow-hidden shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] border-4 border-black"
>
  <div
    class="absolute -bottom-16 -left-16 w-40 h-40 bg-purple-500/5 blur-3xl pointer-events-none"
  >
  </div>

  <div class="relative z-10 space-y-6">
    <h3 class="text-xl font-bold text-black flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 text-brand-lime"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
        ></path><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
      >
      Configuración
    </h3>

    <div class="space-y-4">
      <p
        class="text-sm text-black font-black uppercase tracking-wider px-1 border-b-4 border-brand-lime inline-block mb-2"
      >
        General
      </p>

      <div
        class="flex items-center justify-between p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 bg-brand-lime/10 flex items-center justify-center text-brand-lime shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
              ></path></svg
            >
          </div>
          <span class="text-black text-sm font-medium">Notificaciones</span>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input
            type="checkbox"
            checked
            class="sr-only peer"
            id="notificaciones-toggle"
          />
          <div
            class="w-11 h-6 bg-slate-700 peer-focus:outline-none peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after: after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-lime"
          >
          </div>
        </label>
      </div>

      <button
        class="w-full flex items-center justify-between p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all group mt-4 h-auto"
        onclick="alert('Función de cambiar tema próximamente disponible')"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 bg-indigo-500/10 flex items-center justify-center text-indigo-400 group-hover:text-brand-lime transition-colors shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              ></path></svg
            >
          </div>
          <span class="text-black text-sm font-medium">Apariencia</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-black font-semibold text-xs"
            >Modo Oscuro - Activado</span
          >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 text-black font-semibold group-hover:text-brand-lime transition-colors shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path></svg
          >
        </div>
      </button>
    </div>

    <div class="space-y-4 pt-4 border-t-4 border-black">
      <p
        class="text-sm text-black font-black uppercase tracking-wider px-1 border-b-4 border-brand-lime inline-block mb-2"
      >
        Soporte y Legal
      </p>

      <button
        class="w-full flex items-center justify-between p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all group"
        onclick="showFAQModal()"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 bg-blue-500/10 flex items-center justify-center text-blue-400 group-hover:text-brand-lime transition-colors shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path></svg
            >
          </div>
          <span class="text-black text-sm font-medium">Centro de Ayuda</span>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 text-black font-semibold group-hover:text-brand-lime transition-colors shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path></svg
        >
      </button>

      <button
        class="w-full flex items-center justify-between p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all group mt-4 h-auto"
        onclick="alert('Abriendo Términos y Condiciones...')"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 bg-purple-500/10 flex items-center justify-center text-purple-400 group-hover:text-brand-lime transition-colors shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path></svg
            >
          </div>
          <span class="text-black text-sm font-medium"
            >Términos y Condiciones</span
          >
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 text-black font-semibold group-hover:text-brand-lime transition-colors shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path></svg
        >
      </button>

      <button
        class="w-full flex items-center justify-between p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all group mt-4 h-auto"
        onclick="alert('Abriendo Políticas de Privacidad...')"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 bg-green-500/10 flex items-center justify-center text-green-400 group-hover:text-brand-lime transition-colors shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
              ></path></svg
            >
          </div>
          <span class="text-black text-sm font-medium"
            >Políticas de Privacidad</span
          >
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 text-black font-semibold group-hover:text-brand-lime transition-colors shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path></svg
        >
      </button>
    </div>

    <div class="space-y-4 pt-4 border-t-4 border-black">
      <p
        class="text-sm text-black font-black uppercase tracking-wider px-1 border-b-4 border-brand-lime inline-block mb-2"
      >
        Seguridad de la Cuenta
      </p>

      <button
        class="w-full flex items-center justify-between p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all group"
        onclick="showSecurityModal()"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 bg-red-500/10 flex items-center justify-center text-red-400 group-hover:text-brand-lime transition-colors shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path></svg
            >
          </div>
          <div class="flex-1 text-left">
            <span class="text-black text-sm font-medium">Seguridad</span>
            <p class="text-black font-semibold text-xs">Gestión de cuenta</p>
          </div>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 text-black font-semibold group-hover:text-brand-lime transition-colors shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path></svg
        >
      </button>
    </div>

    <div class="space-y-4 pt-4 border-t-4 border-black">
      <p
        class="text-sm text-black font-black uppercase tracking-wider px-1 border-b-4 border-brand-lime inline-block mb-2"
      >
        Sesión
      </p>

      <button
        class="w-full flex items-center justify-center gap-2 p-5 bg-white border-4 border-black hover:-translate-y-1 shadow-[4px_4px_0_0_#000] hover:shadow-none transition-all group"
        onclick="showLogoutModal()"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-black font-bold group-hover:text-brand-lime transition-colors"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
          ></path></svg
        >
        <span
          class="text-black font-bold text-sm font-medium group-hover:text-brand-lime transition-colors"
          >Cerrar Sesión</span
        >
      </button>

      <button
        class="w-full flex items-center justify-center gap-2 p-3 bg-red-500/10 border border-red-500/20 hover:bg-red-500/20 hover:border-red-500/40 transition-all group"
        onclick="confirmarEliminacionCuenta()"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-red-400 group-hover:text-red-500 transition-colors"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
          ></path></svg
        >
        <span
          class="text-red-400 text-sm font-medium group-hover:text-red-500 transition-colors"
          >Eliminar mi Cuenta</span
        >
      </button>
    </div>
  </div>
</Card>
