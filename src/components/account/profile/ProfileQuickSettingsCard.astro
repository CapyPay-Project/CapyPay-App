---
import { Card, Button } from "../../ui";
---

<Card class="p-6! relative overflow-hidden shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] border-4 border-black ">
  <div
    class="absolute -bottom-16 -right-16 w-40 h-40 bg-green-500/5  blur-3xl pointer-events-none"
  >
  </div>

  <div class="relative z-10">
    <h3 class="text-lg font-bold text-black mb-6 flex items-center gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 text-brand-lime"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
        ></path></svg
      >
      Ajustes rápidos de Perfil
    </h3>

    <div class="space-y-4">
      <div
        class="flex items-center justify-between p-4 bg-white border-2 border-black  border-4 border-black hover:border-brand-lime/30 transition-all"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10  bg-brand-lime/10 flex items-center justify-center text-brand-lime"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-black font-medium text-sm">Editar Username</p>
            <p id="alias-settings" class="text-black font-semibold text-xs">
              @angel.capy
            </p>
          </div>
        </div>
        <Button id="btn-edit-profile" variant="secondary" size="sm"
          >Editar</Button
        >
      </div>

      <div
        class="flex items-center justify-between p-4 bg-white border-2 border-black  border-4 border-black hover:border-brand-lime/30 transition-all"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10  bg-purple-500/10 flex items-center justify-center text-purple-400"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-black font-medium text-sm">
              Notificaciones de Gastos
            </p>
            <p class="text-black font-semibold text-xs">Alertas en cada transacción</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" checked class="sr-only peer" />
          <div
            class="w-11 h-6 bg-slate-700 peer-focus:outline-none  peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after: after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-lime"
          >
          </div>
        </label>
      </div>

      <div
        class="flex items-center justify-between p-4 bg-white border-2 border-black  border-4 border-black hover:border-brand-lime/30 transition-all"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10  bg-slate-700 flex items-center justify-center text-black font-bold"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-black font-medium text-sm">Visibilidad de Perfil</p>
            <p class="text-black font-semibold text-xs">Perfil privado</p>
          </div>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" class="sr-only peer" />
          <div
            class="w-11 h-6 bg-slate-700 peer-focus:outline-none  peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after: after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-lime"
          >
          </div>
        </label>
      </div>
    </div>
  </div>
</Card>
