---
import { Input } from "../../ui";
---

<div class="flex flex-col sm:flex-row gap-3">
  <div class="relative flex-1">
    <Input
      id="search-input"
      autocomplete="off"
      placeholder="Buscar por nombre, cédula o alias..."
    >
      <svg
        slot="icon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </Input>
  </div>

  <div
    class="flex p-1 bg-black  border-4 border-black self-stretch sm:self-auto shrink-0"
  >
    <button
      class="px-3 py-2  text-xs font-bold bg-brand-lime text-black border-2 border-black transition-all filter-btn"
      data-filter="all">Todos</button
    >
    <button
      class="px-3 py-2  text-xs font-bold text-black font-semibold hover:text-black transition-all filter-btn"
      data-filter="recent">Recientes</button
    >
    <button
      class="px-3 py-2  text-xs font-bold text-black font-semibold hover:text-black transition-all filter-btn"
      data-filter="favorites">Favoritos</button
    >
  </div>
</div>
